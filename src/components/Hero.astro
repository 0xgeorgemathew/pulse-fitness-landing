---
import { stats } from "../data/site";
---

<section class="hero" id="top">
  <div class="grid-bg"></div>
  <div class="hero__glow hero__glow--lime" aria-hidden="true"></div>
  <div class="hero__glow hero__glow--orange" aria-hidden="true"></div>

  <div class="container hero__inner">
    <div class="hero__copy reveal">
      <span class="chip chip--lime">
        <span class="dot" aria-hidden="true"></span> Live classes every 30 min
      </span>

      <h1 class="hero__title">
        Train like you
        <span class="hero__title-accent">mean it.</span>
      </h1>

      <p class="hero__lead">
        PULSE is the high-energy fitness app that turns ambition into routine.
        World-class coaches, smart progress tracking, and workouts that
        actually move the needle — wherever you train.
      </p>

      <div class="hero__actions">
        <a href="#pricing" class="btn btn--primary btn--lg">
          Start 14-day free trial
          <svg width="16" height="16" viewBox="0 0 16 16" fill="none">
            <path d="M3 8h9M8 4l4 4-4 4" stroke="currentColor" stroke-width="2"
              stroke-linecap="round" stroke-linejoin="round"/>
          </svg>
        </a>
        <a href="#workouts" class="btn btn--ghost btn--lg">
          <svg width="16" height="16" viewBox="0 0 16 16" fill="none">
            <circle cx="8" cy="8" r="7" stroke="currentColor" stroke-width="1.5"/>
            <path d="M6.5 5.5 L10.5 8 L6.5 10.5 Z" fill="currentColor"/>
          </svg>
          Watch a class
        </a>
      </div>

      <p class="hero__fineprint">
        No credit card. Cancel anytime. <span>Used by 2.4M+ athletes.</span>
      </p>
    </div>

    <div class="hero__visual reveal" style="transition-delay:0.12s">
      <!-- Stylized app preview / phone mockup -->
      <div class="phone">
        <div class="phone__notch"></div>
        <div class="phone__screen">
          <div class="phone__topbar">
            <span class="phone__greet">Good morning, Alex</span>
            <span class="phone__avatar" aria-hidden="true">A</span>
          </div>

          <div class="phone__ring">
            <svg viewBox="0 0 160 160" class="phone__ring-svg">
              <circle cx="80" cy="80" r="68" stroke="rgba(255,255,255,0.08)" stroke-width="10" fill="none"/>
              <circle cx="80" cy="80" r="68" stroke="url(#g)" stroke-width="10" fill="none"
                stroke-linecap="round" stroke-dasharray="427" stroke-dashoffset="120"
                transform="rotate(-90 80 80)"/>
              <defs>
                <linearGradient id="g" x1="0" y1="0" x2="1" y2="1">
                  <stop offset="0%" stop-color="#d4ff3a"/>
                  <stop offset="100%" stop-color="#2ee6ff"/>
                </linearGradient>
              </defs>
            </svg>
            <div class="phone__ring-center">
              <span class="phone__ring-val">72%</span>
              <span class="phone__ring-lbl">weekly goal</span>
            </div>
          </div>

          <div class="phone__now">
            <div class="phone__now-label">Up next</div>
            <div class="phone__now-card">
              <div class="phone__now-tag">HIIT · 28 min</div>
              <div class="phone__now-title">Afterburn</div>
              <div class="phone__now-coach">with Lena Cruz</div>
            </div>
          </div>

          <div class="phone__bars">
            <div class="phone__bar" style="--h:40%"></div>
            <div class="phone__bar" style="--h:70%"></div>
            <div class="phone__bar" style="--h:25%"></div>
            <div class="phone__bar" style="--h:90%"></div>
            <div class="phone__bar" style="--h:60%"></div>
            <div class="phone__bar" style="--h:100%"></div>
            <div class="phone__bar" style="--h:35%"></div>
          </div>
        </div>
      </div>

      <div class="hero__badge hero__badge--streak">
        <span class="hero__badge-num">47</span>
        <span class="hero__badge-lbl">day streak 🔥</span>
      </div>
      <div class="hero__badge hero__badge--kcal">
        <span class="hero__badge-num">540</span>
        <span class="hero__badge-lbl">kcal · today</span>
      </div>
    </div>
  </div>

  <div class="container hero__stats reveal" style="transition-delay:0.2s">
    {stats.map((s) => (
      <div class="hero__stat">
        <span class="hero__stat-val">{s.value}</span>
        <span class="hero__stat-lbl">{s.label}</span>
      </div>
    ))}
  </div>
</section>

<style>
  .hero {
    position: relative;
    padding-top: 60px;
    padding-bottom: 40px;
    overflow: hidden;
  }
  .hero__glow {
    position: absolute;
    border-radius: 50%;
    filter: blur(110px);
    opacity: 0.45;
    pointer-events: none;
    z-index: 0;
  }
  .hero__glow--lime {
    width: 520px; height: 520px;
    background: radial-gradient(circle, var(--lime), transparent 70%);
    top: -180px; left: -120px;
  }
  .hero__glow--orange {
    width: 460px; height: 460px;
    background: radial-gradient(circle, var(--orange), transparent 70%);
    top: 80px; right: -160px;
    opacity: 0.32;
  }

  .hero__inner {
    position: relative;
    z-index: 1;
    display: grid;
    grid-template-columns: 1.05fr 0.95fr;
    gap: 60px;
    align-items: center;
    padding-top: 60px;
  }

  .hero__copy .chip { margin-bottom: 24px; }
  .chip .dot {
    width: 8px; height: 8px;
    border-radius: 50%;
    background: var(--lime);
    box-shadow: 0 0 0 0 rgba(212, 255, 58, 0.6);
    animation: pulse 1.8s infinite;
  }
  @keyframes pulse {
    0% { box-shadow: 0 0 0 0 rgba(212, 255, 58, 0.6); }
    70% { box-shadow: 0 0 0 8px rgba(212, 255, 58, 0); }
    100% { box-shadow: 0 0 0 0 rgba(212, 255, 58, 0); }
  }

  .hero__title {
    font-family: var(--display);
    font-weight: 900;
    font-size: clamp(44px, 7vw, 84px);
    line-height: 0.98;
    letter-spacing: -0.035em;
    margin-bottom: 22px;
  }
  .hero__title-accent {
    display: block;
    background: linear-gradient(105deg, var(--lime) 0%, var(--blue) 90%);
    -webkit-background-clip: text;
    background-clip: text;
    color: transparent;
  }

  .hero__lead {
    color: var(--text-muted);
    font-size: clamp(16px, 2vw, 19px);
    max-width: 52ch;
    margin-bottom: 32px;
  }

  .hero__actions {
    display: flex;
    flex-wrap: wrap;
    gap: 14px;
    margin-bottom: 18px;
  }

  .hero__fineprint {
    color: var(--text-dim);
    font-size: 13.5px;
  }
  .hero__fineprint span { color: var(--text-muted); }

  /* ---------- Phone mockup ---------- */
  .hero__visual {
    position: relative;
    display: grid;
    place-items: center;
    min-height: 520px;
  }
  .phone {
    position: relative;
    width: 300px;
    height: 600px;
    background: #000;
    border-radius: 44px;
    padding: 12px;
    border: 1.5px solid rgba(255, 255, 255, 0.12);
    box-shadow: var(--shadow-lg), 0 0 0 1px rgba(0,0,0,0.5), 0 0 80px -10px rgba(212, 255, 58, 0.25);
    animation: float 6s ease-in-out infinite;
  }
  @keyframes float {
    0%, 100% { transform: translateY(0); }
    50% { transform: translateY(-12px); }
  }
  .phone__notch {
    position: absolute;
    top: 12px; left: 50%;
    transform: translateX(-50%);
    width: 110px; height: 26px;
    background: #000;
    border-radius: 0 0 18px 18px;
    z-index: 2;
  }
  .phone__screen {
    width: 100%; height: 100%;
    background: linear-gradient(170deg, #14141c, #0a0a10);
    border-radius: 34px;
    padding: 40px 22px 22px;
    display: flex;
    flex-direction: column;
    gap: 22px;
    overflow: hidden;
  }
  .phone__topbar {
    display: flex; align-items: center; justify-content: space-between;
  }
  .phone__greet { font-size: 13px; font-weight: 600; color: var(--text-muted); }
  .phone__avatar {
    width: 32px; height: 32px;
    border-radius: 50%;
    background: linear-gradient(135deg, var(--orange), var(--pink));
    display: grid; place-items: center;
    font-size: 13px; font-weight: 800; color: #fff;
  }

  .phone__ring {
    position: relative;
    width: 160px; height: 160px;
    margin: 4px auto 0;
  }
  .phone__ring-svg { width: 100%; height: 100%; }
  .phone__ring-center {
    position: absolute; inset: 0;
    display: grid; place-content: center; text-align: center; gap: 2px;
  }
  .phone__ring-val {
    font-size: 32px; font-weight: 800; letter-spacing: -0.02em;
    background: linear-gradient(105deg, var(--lime), var(--blue));
    -webkit-background-clip: text; background-clip: text; color: transparent;
  }
  .phone__ring-lbl {
    font-size: 11px; color: var(--text-dim);
    text-transform: uppercase; letter-spacing: 0.08em;
  }

  .phone__now-label {
    font-size: 11px; color: var(--text-dim);
    text-transform: uppercase; letter-spacing: 0.1em; margin-bottom: 8px;
  }
  .phone__now-card {
    background: linear-gradient(135deg, rgba(255, 46, 136, 0.18), rgba(255, 90, 44, 0.1));
    border: 1px solid rgba(255, 46, 136, 0.3);
    border-radius: 14px;
    padding: 14px 16px;
  }
  .phone__now-tag {
    font-family: var(--mono); font-size: 10px; font-weight: 700;
    color: var(--pink); text-transform: uppercase; letter-spacing: 0.06em;
  }
  .phone__now-title { font-size: 19px; font-weight: 800; margin-top: 4px; }
  .phone__now-coach { font-size: 12px; color: var(--text-muted); margin-top: 2px; }

  .phone__bars {
    display: flex; align-items: flex-end; gap: 7px;
    height: 70px; margin-top: auto;
  }
  .phone__bar {
    flex: 1; height: var(--h);
    background: linear-gradient(180deg, var(--lime), rgba(212, 255, 58, 0.2));
    border-radius: 4px 4px 0 0;
    animation: barGrow 1.2s cubic-bezier(0.16, 1, 0.3, 1) backwards;
  }
  .phone__bar:nth-child(1) { animation-delay: 0.6s; }
  .phone__bar:nth-child(2) { animation-delay: 0.7s; }
  .phone__bar:nth-child(3) { animation-delay: 0.8s; }
  .phone__bar:nth-child(4) { animation-delay: 0.9s; }
  .phone__bar:nth-child(5) { animation-delay: 1.0s; }
  .phone__bar:nth-child(6) { animation-delay: 1.1s; }
  .phone__bar:nth-child(7) { animation-delay: 1.2s; }
  @keyframes barGrow {
    from { height: 0; opacity: 0; }
  }

  .hero__badge {
    position: absolute;
    background: var(--bg-elev-2);
    border: 1px solid var(--border-strong);
    border-radius: 14px;
    padding: 12px 16px;
    display: flex; flex-direction: column;
    box-shadow: var(--shadow-lg);
  }
  .hero__badge-num {
    font-size: 22px; font-weight: 800; letter-spacing: -0.02em;
  }
  .hero__badge-lbl { font-size: 11px; color: var(--text-muted); }
  .hero__badge--streak {
    top: 40px; right: -10px;
    border-color: rgba(212, 255, 58, 0.4);
  }
  .hero__badge--streak .hero__badge-num { color: var(--lime); }
  .hero__badge--kcal {
    bottom: 50px; left: -20px;
    border-color: rgba(255, 90, 44, 0.4);
  }
  .hero__badge--kcal .hero__badge-num { color: var(--orange); }

  /* ---------- Stats strip ---------- */
  .hero__stats {
    position: relative; z-index: 1;
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: 24px;
    margin-top: 80px;
    padding-top: 40px;
    border-top: 1px solid var(--border);
  }
  .hero__stat { display: flex; flex-direction: column; gap: 4px; }
  .hero__stat-val {
    font-size: clamp(28px, 4vw, 40px);
    font-weight: 800; letter-spacing: -0.03em;
  }
  .hero__stat-lbl {
    font-size: 13px; color: var(--text-muted);
    font-family: var(--mono); text-transform: uppercase; letter-spacing: 0.06em;
  }

  @media (max-width: 980px) {
    .hero__inner { grid-template-columns: 1fr; gap: 40px; }
    .hero__visual { min-height: 480px; order: -1; }
    .hero__badge--streak { right: 20px; }
    .hero__badge--kcal { left: 20px; }
    .hero__stats { grid-template-columns: repeat(2, 1fr); gap: 28px; }
  }
  @media (max-width: 480px) {
    .phone { width: 270px; height: 540px; }
    .hero__badge { padding: 10px 12px; }
    .hero__badge-num { font-size: 18px; }
  }
</style>
