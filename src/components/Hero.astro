---
import { stats } from "../data/site";
---

<section class="hero" id="top">
  <!-- Atmospheric photographic background (decorative) -->
  <div class="hero__photo" aria-hidden="true">
    <img
      class="hero__photo-img"
      src="/img/photo-1517836357463-d25dfeac3438_1600x1000.jpg"
      alt=""
      aria-hidden="true"
      loading="eager"
      decoding="async"
      fetchpriority="high"
    />
    <!-- Accent-tinted cohesion layer over the photo -->
    <div class="hero__photo-tint"></div>
    <!-- Strong vignette + bottom fade into the page background -->
    <div class="hero__photo-overlay"></div>
  </div>

  <div class="grid-bg"></div>
  <div class="hero__glow hero__glow--lime" aria-hidden="true"></div>
  <div class="hero__glow hero__glow--orange" aria-hidden="true"></div>

  <div class="container hero__inner">
    <div class="hero__copy reveal">
      <span class="chip chip--lime">
        <span class="dot" aria-hidden="true"></span> Live classes every 30 min
      </span>

      <h1 class="hero__title">
        Train like you
        <span class="hero__title-accent">mean it.</span>
      </h1>

      <p class="hero__lead">
        Get a personalized week of workouts — free, no signup. World-class
        coaches, smart tracking, and sessions that actually move the needle.
        Love it, then go Pro.
      </p>

      <!-- ============================================================
           FREE VALUE FIRST (reciprocity)
           Pick a goal -> instantly see a 3-workout starter plan.
           No gate, no email, no card. Value before the ask.
           ============================================================ -->
      <div class="freebuild" aria-labelledby="freebuild-label">
        <div class="freebuild__head">
          <span id="freebuild-label" class="freebuild__label">
            Build my free week
          </span>
          <span class="freebuild__tag">No signup · No card</span>
        </div>

        <div
          class="freebuild__chips"
          role="group"
          aria-label="Choose your primary goal to preview a free starter week"
        >
          <button type="button" class="goalchip" data-goal="lose" aria-pressed="false">
            Lose weight
          </button>
          <button type="button" class="goalchip" data-goal="muscle" aria-pressed="false">
            Build muscle
          </button>
          <button type="button" class="goalchip" data-goal="strong" aria-pressed="false">
            Get strong
          </button>
          <button type="button" class="goalchip" data-goal="move" aria-pressed="false">
            Move better
          </button>
        </div>

        <!-- Revealed starter plan (hidden until a chip is chosen) -->
        <div
          class="freebuild__reveal"
          id="freebuild-reveal"
          hidden
          aria-live="polite"
        >
          <div class="freebuild__reveal-head">
            <span class="freebuild__reveal-eyebrow">Here's your starter plan ↓</span>
            <span class="freebuild__reveal-title" id="freebuild-title">
              Your week
            </span>
            <span class="freebuild__reveal-meta" id="freebuild-meta">
              3 sessions · free preview
            </span>
          </div>
          <ul class="freebuild__list" id="freebuild-list">
            <!-- Filled by script -->
          </ul>
          <p class="freebuild__note">
            Yours to keep — the full 7-day plan unlocks when you start your trial.
          </p>
        </div>
      </div>

      <div class="hero__actions">
        <!-- PRIMARY = receive value first (reciprocity) -->
        <a href="#workouts" class="btn btn--primary btn--lg">
          Build my free week
          <svg width="16" height="16" viewBox="0 0 16 16" fill="none">
            <path d="M3 8h9M8 4l4 4-4 4" stroke="currentColor" stroke-width="2"
              stroke-linecap="round" stroke-linejoin="round"/>
          </svg>
        </a>
        <!-- SECONDARY = commitment (deferred until value delivered) -->
        <a href="#pricing" class="btn btn--ghost btn--lg">
          Start 14-day trial
        </a>
        <!-- TERTIARY = low-pressure -->
        <a href="#workouts" class="btn btn--ghost btn--lg hero__actions--ghost-tertiary">
          <svg width="16" height="16" viewBox="0 0 16 16" fill="none" aria-hidden="true">
            <circle cx="8" cy="8" r="7" stroke="currentColor" stroke-width="1.5"/>
            <path d="M6.5 5.5 L10.5 8 L6.5 10.5 Z" fill="currentColor"/>
          </svg>
          Watch a class
        </a>
      </div>

      <p class="hero__fineprint">
        Free week is genuinely free. <span>Used by 2.4M+ athletes.</span>
      </p>
    </div>

    <div class="hero__visual reveal" style="transition-delay:0.12s">
      <!-- Stylized app preview / phone mockup — tied to "Your week" concept -->
      <div class="phone">
        <div class="phone__notch"></div>
        <div class="phone__screen">
          <div class="phone__topbar">
            <span class="phone__greet">Your week</span>
            <span class="phone__pill">Free preview</span>
          </div>

          <!-- Week grid: 3 active workout tiles reinforce "free week" value -->
          <div class="phone__week">
            <div class="phone__day phone__day--active">
              <span class="phone__day-d">Mon</span>
              <span class="phone__day-t">Afterburn</span>
              <span class="phone__day-m">HIIT · 28m</span>
            </div>
            <div class="phone__day phone__day--rest">
              <span class="phone__day-d">Tue</span>
              <span class="phone__day-t">Rest</span>
              <span class="phone__day-m">Recovery</span>
            </div>
            <div class="phone__day phone__day--active">
              <span class="phone__day-d">Wed</span>
              <span class="phone__day-t">Iron Stack</span>
              <span class="phone__day-m">Strength · 42m</span>
            </div>
            <div class="phone__day phone__day--active">
              <span class="phone__day-d">Thu</span>
              <span class="phone__day-t">Reset</span>
              <span class="phone__day-m">Mobility · 18m</span>
            </div>
            <div class="phone__day phone__day--locked">
              <span class="phone__day-d">Fri</span>
              <span class="phone__day-t">—</span>
              <span class="phone__day-m">Unlocks in trial</span>
            </div>
          </div>

          <div class="phone__ring">
            <svg viewBox="0 0 160 160" class="phone__ring-svg">
              <circle cx="80" cy="80" r="68" stroke="rgba(255,255,255,0.08)" stroke-width="10" fill="none"/>
              <circle cx="80" cy="80" r="68" stroke="url(#g)" stroke-width="10" fill="none"
                stroke-linecap="round" stroke-dasharray="427" stroke-dashoffset="120"
                transform="rotate(-90 80 80)"/>
              <defs>
                <linearGradient id="g" x1="0" y1="0" x2="1" y2="1">
                  <stop offset="0%" stop-color="#d4ff3a"/>
                  <stop offset="100%" stop-color="#2ee6ff"/>
                </linearGradient>
              </defs>
            </svg>
            <div class="phone__ring-center">
              <span class="phone__ring-val">3/5</span>
              <span class="phone__ring-lbl">free sessions</span>
            </div>
          </div>

          <div class="phone__now">
            <div class="phone__now-label">Up next</div>
            <div class="phone__now-card">
              <div class="phone__now-tag">HIIT · 28 min</div>
              <div class="phone__now-title">Afterburn</div>
              <div class="phone__now-coach">with Lena Cruz</div>
            </div>
          </div>

          <div class="phone__bars" aria-hidden="true">
            <div class="phone__bar" style="--h:40%"></div>
            <div class="phone__bar" style="--h:70%"></div>
            <div class="phone__bar" style="--h:25%"></div>
            <div class="phone__bar" style="--h:90%"></div>
            <div class="phone__bar" style="--h:60%"></div>
            <div class="phone__bar" style="--h:100%"></div>
            <div class="phone__bar" style="--h:35%"></div>
          </div>
        </div>
        <!-- Premium glow puddle beneath the device -->
        <span class="phone__glow" aria-hidden="true"></span>
      </div>

      <!-- Floating frosted-glass stat badges -->
      <div class="hero__badge hero__badge--streak">
        <span class="hero__badge-dot" aria-hidden="true"></span>
        <span class="hero__badge-num">5</span>
        <span class="hero__badge-lbl">free workouts</span>
      </div>
      <div class="hero__badge hero__badge--kcal">
        <span class="hero__badge-dot" aria-hidden="true"></span>
        <span class="hero__badge-num">$0</span>
        <span class="hero__badge-lbl">no card needed</span>
      </div>
    </div>
  </div>

  <div class="container hero__stats reveal" style="transition-delay:0.2s">
    {stats.map((s) => (
      <div class="hero__stat">
        <span class="hero__stat-val">{s.value}</span>
        <span class="hero__stat-lbl">{s.label}</span>
      </div>
    ))}
  </div>
</section>

<style>
  .hero {
    position: relative;
    padding-top: 60px;
    padding-bottom: 40px;
    overflow: hidden;
  }

  /* ---------- Atmospheric photo background ---------- */
  .hero__photo {
    position: absolute;
    inset: 0;
    z-index: 0;
    pointer-events: none;
  }
  .hero__photo-img {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    object-fit: cover;
    object-position: center;
    opacity: 0.34;
  }
  /* Accent-tinted cohesion layer (lime wash at low opacity) */
  .hero__photo-tint {
    position: absolute;
    inset: 0;
    background:
      radial-gradient(ellipse 65% 55% at 22% 28%, rgba(212, 255, 58, 0.12), transparent 70%),
      radial-gradient(ellipse 55% 45% at 82% 18%, rgba(46, 230, 255, 0.08), transparent 72%);
    mix-blend-mode: screen;
  }
  /* Strong vignette (transparent center -> solid bg at edges) + bottom fade */
  .hero__photo-overlay {
    position: absolute;
    inset: 0;
    background:
      radial-gradient(ellipse 78% 70% at 50% 40%, transparent 26%, rgba(8, 8, 11, 0.55) 64%, var(--bg) 100%),
      linear-gradient(180deg, rgba(8, 8, 11, 0.6) 0%, transparent 24%, transparent 52%, var(--bg) 100%);
  }

  /* ---------- Glows (over the photo) ---------- */
  .hero__glow {
    position: absolute;
    border-radius: 50%;
    filter: blur(110px);
    pointer-events: none;
    z-index: 0;
  }
  .hero__glow--lime {
    width: 560px; height: 560px;
    background: radial-gradient(circle, var(--lime), transparent 70%);
    top: -200px; left: -140px;
    opacity: 0.42;
  }
  .hero__glow--orange {
    width: 480px; height: 480px;
    background: radial-gradient(circle, var(--orange), transparent 70%);
    top: 80px; right: -160px;
    opacity: 0.32;
  }

  .hero__inner {
    position: relative;
    z-index: 1;
    display: grid;
    grid-template-columns: 1.05fr 0.95fr;
    gap: 60px;
    align-items: center;
    padding-top: 60px;
  }

  .hero__copy .chip { margin-bottom: 24px; }
  .chip .dot {
    width: 8px; height: 8px;
    border-radius: 50%;
    background: var(--lime);
    box-shadow: 0 0 0 0 rgba(212, 255, 58, 0.6);
    animation: pulse 1.8s infinite;
  }
  @keyframes pulse {
    0% { box-shadow: 0 0 0 0 rgba(212, 255, 58, 0.6); }
    70% { box-shadow: 0 0 0 8px rgba(212, 255, 58, 0); }
    100% { box-shadow: 0 0 0 0 rgba(212, 255, 58, 0); }
  }

  /* ---------- Headline ---------- */
  .hero__title {
    font-family: var(--display);
    font-weight: 900;
    font-size: clamp(44px, 7vw, 84px);
    line-height: 0.98;
    letter-spacing: -0.035em;
    margin-bottom: 26px;
    text-shadow: 0 2px 30px rgba(0, 0, 0, 0.55);
  }
  .hero__title-accent {
    display: block;
    width: fit-content;
    position: relative;
    background: linear-gradient(100deg, var(--lime) 0%, #7dffb0 42%, var(--blue) 95%);
    -webkit-background-clip: text;
    background-clip: text;
    color: transparent;
    filter:
      drop-shadow(0 2px 14px rgba(212, 255, 58, 0.35))
      drop-shadow(0 4px 26px rgba(46, 230, 255, 0.28));
  }
  .hero__title-accent::after {
    content: "";
    position: absolute;
    left: 0;
    bottom: -8px;
    width: 100%;
    height: 5px;
    border-radius: 3px;
    background: linear-gradient(90deg, var(--lime), var(--blue));
    box-shadow: 0 0 18px rgba(212, 255, 58, 0.55);
    transform-origin: left center;
    animation: drawLine 1.3s cubic-bezier(0.16, 1, 0.3, 1) 0.5s backwards;
    opacity: 0.95;
  }
  @keyframes drawLine {
    from { transform: scaleX(0); opacity: 0; }
    to   { transform: scaleX(1); opacity: 0.95; }
  }

  .hero__lead {
    color: var(--text-muted);
    font-size: clamp(16px, 2vw, 19px);
    max-width: 52ch;
    margin-bottom: 28px;
    text-shadow: 0 1px 16px rgba(0, 0, 0, 0.4);
  }

  /* ============================================================
     FREE VALUE-FIRST BUILDER (reciprocity micro-interaction)
     ============================================================ */
  .freebuild {
    position: relative;
    background: rgba(255, 255, 255, 0.035);
    -webkit-backdrop-filter: blur(14px) saturate(150%);
    backdrop-filter: blur(14px) saturate(150%);
    border: 1px solid rgba(255, 255, 255, 0.1);
    border-radius: 18px;
    padding: 18px 18px 20px;
    margin-bottom: 24px;
    box-shadow:
      0 12px 40px -16px rgba(0, 0, 0, 0.6),
      inset 0 1px 0 rgba(255, 255, 255, 0.06);
  }
  .freebuild__head {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 12px;
    margin-bottom: 14px;
    flex-wrap: wrap;
  }
  .freebuild__label {
    font-family: var(--display);
    font-size: 15px;
    font-weight: 800;
    letter-spacing: -0.01em;
    color: var(--text);
    display: inline-flex;
    align-items: center;
    gap: 8px;
  }
  .freebuild__label::before {
    content: "✦";
    color: var(--lime);
    font-size: 13px;
    filter: drop-shadow(0 0 6px rgba(212, 255, 58, 0.6));
  }
  .freebuild__tag {
    font-family: var(--mono);
    font-size: 10px;
    font-weight: 600;
    letter-spacing: 0.06em;
    text-transform: uppercase;
    color: var(--lime);
    background: rgba(212, 255, 58, 0.1);
    border: 1px solid rgba(212, 255, 58, 0.28);
    padding: 4px 8px;
    border-radius: 999px;
  }

  .freebuild__chips {
    display: flex;
    flex-wrap: wrap;
    gap: 8px;
  }
  .goalchip {
    font-family: var(--sans);
    font-size: 13.5px;
    font-weight: 600;
    letter-spacing: -0.01em;
    color: var(--text-muted);
    background: rgba(255, 255, 255, 0.04);
    border: 1px solid var(--border-strong);
    border-radius: 999px;
    padding: 9px 16px;
    cursor: pointer;
    transition: color 0.18s var(--ease-out),
                background 0.18s var(--ease-out),
                border-color 0.18s var(--ease-out),
                transform 0.18s var(--ease-out),
                box-shadow 0.2s var(--ease-out);
  }
  .goalchip:hover {
    color: var(--text);
    border-color: rgba(212, 255, 58, 0.5);
    transform: translateY(-1px);
  }
  .goalchip:focus-visible {
    outline: 2px solid var(--lime);
    outline-offset: 2px;
  }
  .goalchip[aria-pressed="true"] {
    color: #08080b;
    background: var(--lime);
    border-color: var(--lime);
    box-shadow: 0 0 24px rgba(212, 255, 58, 0.45);
  }

  /* Revealed starter plan */
  .freebuild__reveal {
    margin-top: 16px;
    padding-top: 16px;
    border-top: 1px dashed rgba(255, 255, 255, 0.12);
    animation: revealIn 0.4s var(--ease-out);
  }
  .freebuild__reveal[hidden] { display: none; }
  @keyframes revealIn {
    from { opacity: 0; transform: translateY(6px); }
    to   { opacity: 1; transform: translateY(0); }
  }
  .freebuild__reveal-head {
    display: flex;
    flex-direction: column;
    gap: 2px;
    margin-bottom: 12px;
  }
  .freebuild__reveal-eyebrow {
    font-family: var(--mono);
    font-size: 11px;
    font-weight: 600;
    letter-spacing: 0.06em;
    text-transform: uppercase;
    color: var(--lime);
  }
  .freebuild__reveal-title {
    font-family: var(--display);
    font-size: 18px;
    font-weight: 800;
    letter-spacing: -0.015em;
  }
  .freebuild__reveal-meta {
    font-size: 12.5px;
    color: var(--text-dim);
  }
  .freebuild__list {
    display: flex;
    flex-direction: column;
    gap: 8px;
  }
  .freebuild__list li {
    display: flex;
    align-items: center;
    gap: 12px;
    background: rgba(255, 255, 255, 0.03);
    border: 1px solid var(--border);
    border-radius: 12px;
    padding: 10px 12px;
  }
  .freebuild__num {
    flex-shrink: 0;
    width: 26px; height: 26px;
    display: grid; place-items: center;
    border-radius: 8px;
    font-family: var(--mono);
    font-size: 12px;
    font-weight: 700;
    color: #08080b;
    background: linear-gradient(135deg, var(--lime), var(--blue));
  }
  .freebuild__w-title {
    font-size: 14px;
    font-weight: 700;
    color: var(--text);
  }
  .freebuild__w-meta {
    font-family: var(--mono);
    font-size: 11px;
    color: var(--text-dim);
    margin-left: auto;
    white-space: nowrap;
  }
  .freebuild__note {
    margin-top: 12px;
    font-size: 12px;
    color: var(--text-dim);
    font-style: italic;
  }

  .hero__actions {
    display: flex;
    flex-wrap: wrap;
    gap: 14px;
    margin-bottom: 18px;
  }

  .hero__fineprint {
    color: var(--text-dim);
    font-size: 13.5px;
  }
  .hero__fineprint span { color: var(--text-muted); }

  /* ---------- Phone mockup ---------- */
  .hero__visual {
    position: relative;
    display: grid;
    place-items: center;
    min-height: 520px;
  }
  .phone {
    position: relative;
    width: 300px;
    height: 600px;
    background: #000;
    border-radius: 44px;
    padding: 12px;
    border: 1.5px solid rgba(255, 255, 255, 0.14);
    box-shadow:
      0 50px 90px -28px rgba(0, 0, 0, 0.85),
      0 28px 60px -30px rgba(212, 255, 58, 0.4),
      0 0 0 1px rgba(0, 0, 0, 0.5),
      inset 0 0 0 1px rgba(255, 255, 255, 0.04);
    animation: float 6s ease-in-out infinite;
  }
  /* Soft accent reflection / glow puddle beneath the device */
  .phone__glow {
    position: absolute;
    left: 50%;
    bottom: -34px;
    transform: translateX(-50%);
    width: 78%;
    height: 54px;
    background: radial-gradient(ellipse at center,
      rgba(212, 255, 58, 0.32) 0%,
      rgba(46, 230, 255, 0.12) 45%,
      transparent 75%);
    filter: blur(18px);
    z-index: -1;
    pointer-events: none;
  }
  @keyframes float {
    0%, 100% { transform: translateY(0); }
    50% { transform: translateY(-12px); }
  }
  .phone__notch {
    position: absolute;
    top: 12px; left: 50%;
    transform: translateX(-50%);
    width: 110px; height: 26px;
    background: #000;
    border-radius: 0 0 18px 18px;
    z-index: 2;
  }
  .phone__screen {
    width: 100%; height: 100%;
    background: linear-gradient(170deg, #14141c, #0a0a10);
    border-radius: 34px;
    padding: 40px 18px 18px;
    display: flex;
    flex-direction: column;
    gap: 16px;
    overflow: hidden;
  }
  .phone__topbar {
    display: flex; align-items: center; justify-content: space-between;
  }
  .phone__greet { font-size: 14px; font-weight: 700; color: var(--text); }
  .phone__pill {
    font-family: var(--mono);
    font-size: 9px;
    font-weight: 700;
    letter-spacing: 0.06em;
    text-transform: uppercase;
    color: var(--lime);
    background: rgba(212, 255, 58, 0.12);
    border: 1px solid rgba(212, 255, 58, 0.3);
    border-radius: 999px;
    padding: 3px 8px;
  }

  /* Week grid — reinforces the "free week" value concept */
  .phone__week {
    display: grid;
    grid-template-columns: repeat(5, 1fr);
    gap: 5px;
  }
  .phone__day {
    display: flex;
    flex-direction: column;
    gap: 2px;
    padding: 8px 5px;
    border-radius: 9px;
    border: 1px solid rgba(255, 255, 255, 0.06);
    background: rgba(255, 255, 255, 0.02);
    min-height: 56px;
  }
  .phone__day-d {
    font-family: var(--mono);
    font-size: 9px;
    color: var(--text-dim);
    text-transform: uppercase;
    letter-spacing: 0.04em;
  }
  .phone__day-t {
    font-size: 10px;
    font-weight: 700;
    color: var(--text);
    line-height: 1.1;
  }
  .phone__day-m {
    font-size: 8.5px;
    color: var(--text-dim);
    line-height: 1.1;
  }
  .phone__day--active {
    background: rgba(212, 255, 58, 0.08);
    border-color: rgba(212, 255, 58, 0.3);
  }
  .phone__day--active .phone__day-t { color: var(--lime); }
  .phone__day--rest .phone__day-t { color: var(--text-muted); }
  .phone__day--locked {
    opacity: 0.5;
    border-style: dashed;
  }
  .phone__day--locked .phone__day-t { color: var(--text-dim); font-size: 12px; }

  .phone__ring {
    position: relative;
    width: 130px; height: 130px;
    margin: 0 auto;
  }
  .phone__ring-svg { width: 100%; height: 100%; }
  .phone__ring-center {
    position: absolute; inset: 0;
    display: grid; place-content: center; text-align: center; gap: 2px;
  }
  .phone__ring-val {
    font-size: 28px; font-weight: 800; letter-spacing: -0.02em;
    background: linear-gradient(105deg, var(--lime), var(--blue));
    -webkit-background-clip: text; background-clip: text; color: transparent;
  }
  .phone__ring-lbl {
    font-size: 9.5px; color: var(--text-dim);
    text-transform: uppercase; letter-spacing: 0.08em;
  }

  .phone__now-label {
    font-size: 10px; color: var(--text-dim);
    text-transform: uppercase; letter-spacing: 0.1em; margin-bottom: 6px;
  }
  .phone__now-card {
    background: linear-gradient(135deg, rgba(255, 46, 136, 0.18), rgba(255, 90, 44, 0.1));
    border: 1px solid rgba(255, 46, 136, 0.3);
    border-radius: 14px;
    padding: 12px 14px;
  }
  .phone__now-tag {
    font-family: var(--mono); font-size: 10px; font-weight: 700;
    color: var(--pink); text-transform: uppercase; letter-spacing: 0.06em;
  }
  .phone__now-title { font-size: 18px; font-weight: 800; margin-top: 4px; }
  .phone__now-coach { font-size: 11px; color: var(--text-muted); margin-top: 2px; }

  .phone__bars {
    display: flex; align-items: flex-end; gap: 6px;
    height: 48px; margin-top: auto;
  }
  .phone__bar {
    flex: 1; height: var(--h);
    background: linear-gradient(180deg, var(--lime), rgba(212, 255, 58, 0.2));
    border-radius: 4px 4px 0 0;
    animation: barGrow 1.2s cubic-bezier(0.16, 1, 0.3, 1) backwards;
  }
  .phone__bar:nth-child(1) { animation-delay: 0.6s; }
  .phone__bar:nth-child(2) { animation-delay: 0.7s; }
  .phone__bar:nth-child(3) { animation-delay: 0.8s; }
  .phone__bar:nth-child(4) { animation-delay: 0.9s; }
  .phone__bar:nth-child(5) { animation-delay: 1.0s; }
  .phone__bar:nth-child(6) { animation-delay: 1.1s; }
  .phone__bar:nth-child(7) { animation-delay: 1.2s; }
  @keyframes barGrow {
    from { height: 0; opacity: 0; }
  }

  /* ---------- Floating frosted-glass stat badges ---------- */
  .hero__badge {
    position: absolute;
    z-index: 3;
    background: rgba(255, 255, 255, 0.05);
    backdrop-filter: blur(20px) saturate(160%);
    -webkit-backdrop-filter: blur(20px) saturate(160%);
    border: 1px solid rgba(255, 255, 255, 0.12);
    border-radius: 16px;
    padding: 14px 18px;
    display: flex;
    flex-direction: column;
    gap: 2px;
    box-shadow:
      0 8px 32px rgba(0, 0, 0, 0.3),
      inset 0 1px 0 rgba(255, 255, 255, 0.08);
    min-width: 120px;
    animation: floatBadge 7s ease-in-out infinite;
  }
  @keyframes floatBadge {
    0%, 100% { transform: translateY(0); }
    50% { transform: translateY(-8px); }
  }
  .hero__badge-dot {
    width: 8px; height: 8px;
    border-radius: 50%;
    margin-bottom: 6px;
    position: relative;
  }
  .hero__badge-dot::after {
    content: "";
    position: absolute;
    inset: -4px;
    border-radius: 50%;
    border: 1px solid currentColor;
    opacity: 0.4;
    animation: dotPing 2s ease-out infinite;
  }
  @keyframes dotPing {
    0% { transform: scale(0.7); opacity: 0.6; }
    100% { transform: scale(1.6); opacity: 0; }
  }
  .hero__badge-num {
    font-family: var(--display);
    font-size: 26px;
    font-weight: 800;
    letter-spacing: -0.02em;
    line-height: 1;
  }
  .hero__badge-lbl {
    font-size: 11px;
    color: var(--text-muted);
    font-family: var(--mono);
    text-transform: uppercase;
    letter-spacing: 0.06em;
    margin-top: 4px;
  }
  .hero__badge--streak {
    top: 36px;
    right: -14px;
    animation-delay: 0.4s;
  }
  .hero__badge--streak .hero__badge-dot {
    background: var(--lime);
    color: var(--lime);
    box-shadow: 0 0 12px rgba(212, 255, 58, 0.9);
  }
  .hero__badge--streak .hero__badge-num { color: var(--lime); }
  .hero__badge--kcal {
    bottom: 56px;
    left: -24px;
    animation-delay: 1.1s;
  }
  .hero__badge--kcal .hero__badge-dot {
    background: var(--orange);
    color: var(--orange);
    box-shadow: 0 0 12px rgba(255, 90, 44, 0.9);
  }
  .hero__badge--kcal .hero__badge-num { color: var(--orange); }

  /* ---------- Stats strip ---------- */
  .hero__stats {
    position: relative;
    z-index: 1;
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: 24px;
    margin-top: 80px;
    padding-top: 40px;
    border-top: none;
  }
  .hero__stats::before {
    content: "";
    position: absolute;
    top: 0;
    left: 0;
    right: 0;
    height: 1px;
    background: linear-gradient(90deg,
      transparent 0%,
      rgba(212, 255, 58, 0.55) 18%,
      rgba(46, 230, 255, 0.5) 50%,
      rgba(212, 255, 58, 0.55) 82%,
      transparent 100%);
    box-shadow: 0 0 18px rgba(212, 255, 58, 0.25);
  }
  .hero__stat {
    display: flex;
    flex-direction: column;
    gap: 6px;
    padding: 12px 6px;
    border-radius: 12px;
    transition: transform 0.25s ease;
  }
  .hero__stat:hover { transform: translateY(-4px); }
  .hero__stat-val {
    font-family: var(--display);
    font-size: clamp(40px, 6vw, 64px);
    font-weight: 800;
    letter-spacing: -0.04em;
    line-height: 1;
    background: linear-gradient(160deg, #ffffff 0%, #cfcfd8 100%);
    -webkit-background-clip: text;
    background-clip: text;
    color: transparent;
  }
  .hero__stat-lbl {
    font-size: 12px;
    color: var(--text-muted);
    font-family: var(--mono);
    text-transform: uppercase;
    letter-spacing: 0.06em;
  }

  @media (max-width: 980px) {
    .hero__inner { grid-template-columns: 1fr; gap: 40px; }
    .hero__visual { min-height: 480px; order: -1; }
    .hero__badge--streak { right: 16px; }
    .hero__badge--kcal { left: 16px; }
    .hero__stats { grid-template-columns: repeat(2, 1fr); gap: 28px; }
  }
  @media (max-width: 480px) {
    .phone { width: 270px; height: 540px; }
    .hero__badge { padding: 11px 14px; min-width: 104px; }
    .hero__badge-num { font-size: 22px; }
    .hero__badge--streak { right: 8px; top: 24px; }
    .hero__badge--kcal { left: 8px; bottom: 40px; }
    .freebuild { padding: 15px; }
    .freebuild__head { margin-bottom: 12px; }
    .goalchip { padding: 8px 13px; font-size: 13px; }
    .freebuild__w-meta { display: none; }
  }

  /* Honor reduced-motion: stop ambient loops + ping + reveal animation */
  @media (prefers-reduced-motion: reduce) {
    .phone,
    .hero__badge,
    .hero__badge-dot::after { animation: none; }
    .freebuild__reveal { animation: none; }
  }
</style>

<script>
  // ============================================================
  // Free value-first micro-interaction (reciprocity principle)
  // Pick a goal -> instantly see a 3-workout starter plan.
  // Pure vanilla JS. No gate, no email, no card. Honest free.
  // ============================================================
  (function () {
    type Plan = { title: string; meta: string; sessions: { title: string; meta: string }[] };

    // A few hardcoded sample plans keyed by goal. Real, usable value.
    const PLANS: Record<string, Plan> = {
      lose: {
        title: "Burn & sculpt week",
        meta: "3 sessions · ~640 kcal",
        sessions: [
          { title: "Afterburn", meta: "HIIT · 28 min" },
          { title: "Engine Room", meta: "Cardio · 45 min" },
          { title: "Reset", meta: "Mobility · 18 min" },
        ],
      },
      muscle: {
        title: "Hypertrophy week",
        meta: "3 sessions · push / pull / legs",
        sessions: [
          { title: "Iron Stack", meta: "Strength · 42 min" },
          { title: "Afterburn", meta: "HIIT finisher · 28 min" },
          { title: "Reset", meta: "Mobility · 18 min" },
        ],
      },
      strong: {
        title: "Power builder week",
        meta: "3 sessions · compound focus",
        sessions: [
          { title: "Iron Stack", meta: "Strength · 42 min" },
          { title: "Shadow Round", meta: "Boxing · 30 min" },
          { title: "Engine Room", meta: "Cardio base · 45 min" },
        ],
      },
      move: {
        title: "Mobility & flow week",
        meta: "3 sessions · low impact",
        sessions: [
          { title: "Deep Flow", meta: "Yoga · 35 min" },
          { title: "Reset", meta: "Mobility · 18 min" },
          { title: "Engine Room", meta: "Cardio · 45 min" },
        ],
      },
    };

    const chips = document.querySelectorAll<HTMLButtonElement>(".goalchip");
    const reveal = document.getElementById("freebuild-reveal");
    const titleEl = document.getElementById("freebuild-title");
    const metaEl = document.getElementById("freebuild-meta");
    const listEl = document.getElementById("freebuild-list");

    if (!chips.length || !reveal || !titleEl || !metaEl || !listEl) return;

    function render(plan: Plan) {
      titleEl!.textContent = plan.title;
      metaEl!.textContent = plan.meta;
      listEl!.innerHTML = plan.sessions
        .map(
          (s, i) => `
          <li>
            <span class="freebuild__num" aria-hidden="true">${i + 1}</span>
            <span class="freebuild__w-title">${s.title}</span>
            <span class="freebuild__w-meta">${s.meta}</span>
          </li>`
        )
        .join("");
      reveal!.hidden = false;
    }

    chips.forEach((chip) => {
      chip.addEventListener("click", () => {
        const goal = chip.dataset.goal;
        if (!goal || !(goal in PLANS)) return;

        // toggle aria-pressed across the group (single-select)
        chips.forEach((c) => (c.ariaPressed = "false"));
        chip.ariaPressed = "true";

        render(PLANS[goal]);
      });
    });
  })();
</script>
