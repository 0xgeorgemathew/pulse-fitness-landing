---
import { plans } from "../data/site";

const accentVar = {
  lime: "var(--lime)",
  orange: "var(--orange)",
};

// Annual = monthly billed annually at 20% off, shown as a monthly-equivalent.
// round(monthly * 0.8): $14 -> $11, $39 -> $31, $0 -> $0.
const annualFor = (monthly: number) => Math.round(monthly * 0.8);
---

<section class="section pricing" id="pricing" data-billing="monthly">
  <div class="pricing__glow" aria-hidden="true"></div>
  <div class="container">
    <div class="section-head section-head--center reveal">
      <span class="eyebrow">Plans</span>
      <h2 class="section-title">Pick your <em>gear.</em></h2>
      <p class="section-lead">
        Start free, upgrade when you're ready. No contracts, cancel in two taps,
        and a 30-day money-back guarantee on every paid plan.
      </p>
    </div>

    <!-- Billing toggle -->
    <div class="billing reveal" role="group" aria-label="Billing period">
      <span class="billing__pill" aria-hidden="true"></span>
      <button
        type="button"
        class="billing__btn is-active"
        data-billing-btn="monthly"
        aria-pressed="true"
      >
        Monthly
      </button>
      <button
        type="button"
        class="billing__btn"
        data-billing-btn="annual"
        aria-pressed="false"
      >
        Annual <span class="billing__save">save 20%</span>
      </button>
    </div>

    <div class="plans">
      {plans.map((p) => {
        const annual = annualFor(p.price);
        const paid = p.price > 0;
        return (
          <article
            class={`card plan ${p.featured ? "plan--featured" : ""}`}
            style={`--accent:${accentVar[p.accent]}`}
            data-monthly={p.price}
            data-annual={annual}
            data-paid={paid ? "true" : "false"}
          >
            {p.featured && <span class="plan__ribbon">Most popular</span>}

            <header class="plan__head">
              <h3 class="plan__name">{p.name}</h3>
              <p class="plan__tagline">{p.tagline}</p>

              <div class="plan__price">
                {p.price === 0 ? (
                  <span class="plan__amt" data-price>$0</span>
                ) : (
                  <>
                    <span class="plan__cur">$</span>
                    <span class="plan__amt" data-price>{p.price}</span>
                    <span class="plan__cadence">/mo</span>
                  </>
                )}
              </div>

              {paid && (
                <div class="plan__price-meta">
                  <span class="plan__strike">${p.price}/mo</span>
                  <span class="plan__badge">Save 20%</span>
                </div>
              )}
              <p class="plan__billing-note" data-note></p>
            </header>

            <ul class="plan__features">
              {p.features.map((f) => (
                <li>
                  <svg class="plan__check" width="16" height="16" viewBox="0 0 16 16" fill="none">
                    <path d="M3 8.5 L6.5 12 L13 4.5" stroke="currentColor" stroke-width="2"
                      stroke-linecap="round" stroke-linejoin="round"/>
                  </svg>
                  {f}
                </li>
              ))}
            </ul>

            <a
              href="#"
              class={`btn btn--lg plan__cta ${p.featured ? "btn--orange" : "btn--ghost"}`}
            >
              {p.cta}
            </a>
          </article>
        );
      })}
    </div>

    <p class="pricing__note reveal">
      🔒 Secure checkout · 💳 Visa, Mastercard, Amex, Apple Pay · ↩️ 30-day refund
    </p>
  </div>
</section>

<script>
  const section = document.getElementById("pricing");
  if (section) {
    const reduce = window.matchMedia("(prefers-reduced-motion: reduce)").matches;
    const btns = Array.from(
      section.querySelectorAll<HTMLButtonElement>("[data-billing-btn]")
    );
    const planEls = Array.from(section.querySelectorAll<HTMLElement>(".plan"));

    const render = (mode: "monthly" | "annual") => {
      section.dataset.billing = mode;
      btns.forEach((b) => {
        const active = b.dataset.billingBtn === mode;
        b.setAttribute("aria-pressed", String(active));
        b.classList.toggle("is-active", active);
      });

      planEls.forEach((plan) => {
        const monthly = Number(plan.dataset.monthly);
        const annual = Number(plan.dataset.annual);
        const paid = plan.dataset.paid === "true";
        if (!paid) return;

        const amt = plan.querySelector<HTMLElement>("[data-price]");
        const target = mode === "annual" ? annual : monthly;
        if (!amt) return;

        if (reduce) {
          amt.textContent = String(target);
        } else {
          amt.classList.add("is-switching");
          window.setTimeout(() => {
            amt.textContent = String(target);
            amt.classList.remove("is-switching");
          }, 140);
        }
      });
    };

    btns.forEach((b) => {
      b.addEventListener("click", () => {
        const mode = b.dataset.billingBtn as "monthly" | "annual";
        if (mode && section.dataset.billing !== mode) render(mode);
      });
    });
  }
</script>

<style>
  .pricing { position: relative; overflow: hidden; }
  .pricing__glow {
    position: absolute;
    top: 0; left: 50%;
    transform: translateX(-50%);
    width: 700px; height: 500px;
    background: radial-gradient(ellipse, rgba(255, 90, 44, 0.1), transparent 70%);
    filter: blur(80px);
    pointer-events: none;
  }

  .section-head--center {
    margin-inline: auto;
    text-align: center;
  }
  .section-head--center .eyebrow::before { display: none; }
  .section-head--center .eyebrow { justify-content: center; }
  .section-head--center .section-lead { margin-inline: auto; }

  /* ---------- Billing toggle ---------- */
  .billing {
    position: relative;
    display: flex;
    align-items: center;
    width: fit-content;
    margin: 8px auto 40px;
    padding: 5px;
    background: rgba(255, 255, 255, 0.04);
    border: 1px solid var(--border);
    border-radius: 999px;
    backdrop-filter: blur(14px);
    -webkit-backdrop-filter: blur(14px);
    box-shadow: inset 0 1px 0 rgba(255, 255, 255, 0.05), var(--shadow-sm);
  }

  .billing__pill {
    position: absolute;
    top: 5px;
    left: 5px;
    height: calc(100% - 10px);
    width: calc(50% - 5px);
    border-radius: 999px;
    background: linear-gradient(180deg, var(--orange), #d23a14);
    box-shadow: 0 6px 20px -6px rgba(255, 90, 44, 0.6);
    transition: transform 0.32s cubic-bezier(0.16, 1, 0.3, 1);
    z-index: 0;
  }
  .pricing[data-billing="annual"] .billing__pill {
    transform: translateX(100%);
  }

  .billing__btn {
    position: relative;
    z-index: 1;
    padding: 10px 22px;
    border-radius: 999px;
    font-weight: 700;
    font-size: 14px;
    letter-spacing: -0.01em;
    color: var(--text-muted);
    background: transparent;
    transition: color 0.2s ease;
    display: inline-flex;
    align-items: center;
    gap: 8px;
    white-space: nowrap;
  }
  .billing__btn.is-active { color: #fff; }
  .billing__btn:not(.is-active):hover { color: var(--text); }

  .billing__save {
    font-family: var(--mono);
    font-size: 11px;
    font-weight: 700;
    letter-spacing: 0.02em;
    padding: 2px 7px;
    border-radius: 999px;
    background: rgba(212, 255, 58, 0.14);
    color: var(--lime);
    border: 1px solid rgba(212, 255, 58, 0.3);
  }
  .billing__btn.is-active .billing__save {
    background: rgba(255, 255, 255, 0.18);
    color: #fff;
    border-color: rgba(255, 255, 255, 0.25);
  }

  /* ---------- Plans grid ---------- */
  .plans {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 20px;
    align-items: stretch;
    position: relative;
    z-index: 1;
  }

  /* ---------- Glassy cards ---------- */
  .pricing .plan {
    background: rgba(255, 255, 255, 0.03);
    backdrop-filter: blur(12px);
    -webkit-backdrop-filter: blur(12px);
    border: 1px solid var(--border);
    padding: 32px 28px;
    display: flex; flex-direction: column;
    position: relative;
    transition: transform 0.25s ease, border-color 0.25s ease, box-shadow 0.25s ease;
  }
  .pricing .plan:hover {
    transform: translateY(-4px);
    border-color: var(--border-strong);
  }

  /* Featured: gradient border + glow + lift */
  .plan--featured {
    transform: translateY(-10px);
    box-shadow: 0 30px 70px -24px rgba(255, 90, 44, 0.45),
                inset 0 1px 0 rgba(255, 255, 255, 0.06);
  }
  .plan--featured:hover { transform: translateY(-14px); }
  .plan--featured::before {
    content: "";
    position: absolute;
    inset: 0;
    border-radius: inherit;
    padding: 1.5px;
    background: linear-gradient(155deg,
      var(--accent),
      rgba(255, 255, 255, 0.08) 38%,
      rgba(255, 255, 255, 0.02) 60%,
      var(--accent));
    -webkit-mask: linear-gradient(#000 0 0) content-box, linear-gradient(#000 0 0);
    -webkit-mask-composite: xor;
            mask-composite: exclude;
    pointer-events: none;
    z-index: 1;
  }

  .plan__ribbon {
    position: absolute;
    top: -13px; left: 50%;
    transform: translateX(-50%);
    padding: 6px 14px;
    background: var(--accent);
    color: #08080b;
    border-radius: 999px;
    font-size: 11px; font-weight: 800;
    letter-spacing: 0.06em;
    text-transform: uppercase;
    white-space: nowrap;
    z-index: 2;
    box-shadow: 0 8px 20px -6px rgba(255, 90, 44, 0.5);
  }

  /* ---------- Price block ---------- */
  .plan__head { margin-bottom: 24px; position: relative; z-index: 1; }
  .plan__name {
    font-size: 22px; font-weight: 800; letter-spacing: -0.02em;
  }
  .plan__tagline {
    color: var(--text-muted); font-size: 14px;
    margin-top: 6px; min-height: 40px;
  }
  .plan__price {
    display: flex; align-items: baseline; gap: 2px;
    margin-top: 18px;
  }
  .plan__cur {
    font-size: 22px; font-weight: 700; color: var(--text-muted);
    align-self: flex-start; margin-top: 6px;
  }
  .plan__amt {
    font-family: var(--display);
    font-size: 52px; font-weight: 900;
    letter-spacing: -0.04em; line-height: 1;
    transition: opacity 0.18s ease, transform 0.18s ease;
  }
  .plan__amt.is-switching {
    opacity: 0;
    transform: translateY(-6px);
  }
  .plan__cadence {
    font-size: 14px; color: var(--text-muted);
    margin-left: 6px; align-self: flex-end; margin-bottom: 4px;
  }

  /* Strike + save badge — only meaningful on annual */
  .plan__price-meta {
    display: none;
    align-items: center;
    gap: 8px;
    margin-top: 10px;
  }
  .pricing[data-billing="annual"] .plan[data-paid="true"] .plan__price-meta {
    display: inline-flex;
  }
  .plan__strike {
    font-size: 13px;
    color: var(--text-dim);
    text-decoration: line-through;
  }
  .plan__badge {
    font-family: var(--mono);
    font-size: 10px; font-weight: 700;
    letter-spacing: 0.04em; text-transform: uppercase;
    padding: 3px 8px;
    border-radius: 999px;
    background: rgba(212, 255, 58, 0.12);
    color: var(--lime);
    border: 1px solid rgba(212, 255, 58, 0.28);
  }

  /* "billed annually" note — only on annual */
  .plan__billing-note {
    display: none;
    margin-top: 8px;
    font-size: 12px;
    color: var(--text-dim);
    min-height: 0;
  }
  .pricing[data-billing="annual"] .plan[data-paid="true"] .plan__billing-note {
    display: block;
  }
  .pricing[data-billing="annual"] .plan[data-paid="true"] .plan__billing-note::before {
    content: "billed annually";
  }

  /* ---------- Features ---------- */
  .plan__features {
    display: flex; flex-direction: column; gap: 12px;
    margin: 8px 0 28px;
    padding-top: 22px;
    border-top: 1px solid var(--border);
    flex: 1;
    position: relative; z-index: 1;
  }
  .plan__features li {
    display: flex; align-items: flex-start; gap: 10px;
    font-size: 14px;
    color: var(--text);
    padding-bottom: 12px;
    border-bottom: 1px solid rgba(255, 255, 255, 0.04);
  }
  .plan__features li:last-child { border-bottom: none; padding-bottom: 0; }
  .plan__check {
    color: var(--accent);
    flex-shrink: 0;
    margin-top: 2px;
  }

  .plan__cta {
    width: 100%;
    position: relative; z-index: 1;
  }

  .pricing__note {
    text-align: center;
    margin-top: 36px;
    color: var(--text-dim);
    font-size: 13px;
  }

  /* ---------- Responsive ---------- */
  @media (max-width: 920px) {
    .plans { grid-template-columns: 1fr; max-width: 440px; margin-inline: auto; }
    .plan--featured { transform: none; }
    .plan--featured:hover { transform: translateY(-4px); }
  }

  @media (prefers-reduced-motion: reduce) {
    .plan__amt { transition: none; }
    .billing__pill { transition: none; }
  }
</style>
