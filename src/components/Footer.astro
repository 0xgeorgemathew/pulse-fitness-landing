---
const year = new Date().getFullYear();
const cols = [
  {
    title: "Product",
    links: ["Workouts", "Live classes", "Coaches", "Progress tracking", "Mobile app"],
  },
  {
    title: "Company",
    links: ["About", "Careers", "Press", "Blog", "Contact"],
  },
  {
    title: "Resources",
    links: ["Help center", "Community", "Equipment guide", "API", "Status"],
  },
  {
    title: "Legal",
    links: ["Privacy", "Terms", "Cookies", "Refund policy"],
  },
];
---

<footer class="footer">
  <div class="container">
    <div class="footer__top">
      <div class="footer__brand">
        <a href="#top" class="brand">
          <span class="brand__mark" aria-hidden="true">
            <svg viewBox="0 0 32 32" width="28" height="28">
              <path d="M3 18 L9 18 L12 8 L17 26 L20 13 L22 18 L29 18"
                fill="none" stroke="currentColor" stroke-width="2.6"
                stroke-linecap="round" stroke-linejoin="round"></path>
            </svg>
          </span>
          <span class="brand__name">PULSE</span>
        </a>
        <p class="footer__tagline">
          High-energy fitness for people who train like they mean it.
        </p>
        <div class="footer__social">
          <a href="#" aria-label="Instagram">
            <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
              <rect x="2" y="2" width="20" height="20" rx="5"/>
              <circle cx="12" cy="12" r="4"/>
              <circle cx="17.5" cy="6.5" r="1" fill="currentColor"/>
            </svg>
          </a>
          <a href="#" aria-label="YouTube">
            <svg width="18" height="18" viewBox="0 0 24 24" fill="currentColor">
              <path d="M22.5 6.5a3 3 0 0 0-2.1-2.1C18.5 4 12 4 12 4s-6.5 0-8.4.4A3 3 0 0 0 1.5 6.5C1 8.4 1 12 1 12s0 3.6.5 5.5a3 3 0 0 0 2.1 2.1C5.5 20 12 20 12 20s6.5 0 8.4-.4a3 3 0 0 0 2.1-2.1C23 15.6 23 12 23 12s0-3.6-.5-5.5zM9.75 15.5v-7l6 3.5-6 3.5z"/>
            </svg>
          </a>
          <a href="#" aria-label="TikTok">
            <svg width="18" height="18" viewBox="0 0 24 24" fill="currentColor">
              <path d="M19.6 6.3a4.8 4.8 0 0 1-3.8-2.3 4.8 4.8 0 0 1-.5-1.5h-3.4v13.6a2.7 2.7 0 1 1-2-2.6V9.8a6.1 6.1 0 1 0 5.4 6V9.6a8.2 8.2 0 0 0 4.3 1.5V7.7c-.1 0 0-.1 0-.1z"/>
            </svg>
          </a>
          <a href="#" aria-label="X">
            <svg width="16" height="16" viewBox="0 0 24 24" fill="currentColor">
              <path d="M18.9 2H22l-7 8 8.2 12h-6.4l-5-7.3L6 22H3l7.5-8.6L2.5 2h6.6l4.5 6.6L18.9 2zm-1.1 18h1.7L7.3 4H5.5l12.3 16z"/>
            </svg>
          </a>
        </div>
      </div>

      <nav class="footer__cols" aria-label="Footer">
        {cols.map((col) => (
          <div class="footer__col">
            <h3 class="footer__heading">{col.title}</h3>
            <ul>
              {col.links.map((l) => <li><a href="#">{l}</a></li>)}
            </ul>
          </div>
        ))}
      </nav>
    </div>

    <div class="footer__bottom">
      <span>© {year} PULSE Fitness, Inc. All rights reserved.</span>
      <span class="footer__built">
        Built with Astro · Deployed on Cloudflare Workers
      </span>
    </div>
  </div>
</footer>

<style>
  .footer {
    border-top: 1px solid var(--border);
    background: #06060a;
    padding-block: 64px 32px;
  }
  .footer__top {
    display: grid;
    grid-template-columns: 1.4fr 2.6fr;
    gap: 48px;
    padding-bottom: 48px;
    border-bottom: 1px solid var(--border);
  }

  .footer__brand .brand {
    display: inline-flex; align-items: center; gap: 10px;
    font-weight: 900; font-size: 19px; letter-spacing: 0.04em;
  }
  .footer__brand .brand__mark {
    display: inline-grid; place-items: center;
    width: 36px; height: 36px;
    border-radius: 10px;
    background: linear-gradient(140deg, rgba(212,255,58,0.18), rgba(212,255,58,0.04));
    border: 1px solid rgba(212, 255, 58, 0.35);
    color: var(--lime);
  }
  .footer__tagline {
    color: var(--text-muted); font-size: 14px;
    margin: 16px 0 20px; max-width: 32ch;
  }
  .footer__social {
    display: flex; gap: 10px;
  }
  .footer__social a {
    width: 38px; height: 38px;
    border-radius: 10px;
    border: 1px solid var(--border);
    display: grid; place-items: center;
    color: var(--text-muted);
    transition: all 0.18s ease;
  }
  .footer__social a:hover {
    color: var(--lime); border-color: var(--lime);
    transform: translateY(-2px);
  }

  .footer__cols {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: 24px;
  }
  .footer__heading {
    font-family: var(--mono);
    font-size: 11px; font-weight: 700;
    text-transform: uppercase; letter-spacing: 0.1em;
    color: var(--text-dim);
    margin-bottom: 16px;
  }
  .footer__col ul { display: flex; flex-direction: column; gap: 10px; }
  .footer__col a {
    font-size: 14px;
    color: var(--text-muted);
    transition: color 0.18s ease;
  }
  .footer__col a:hover { color: var(--text); }

  .footer__bottom {
    display: flex; justify-content: space-between; align-items: center;
    flex-wrap: wrap; gap: 12px;
    padding-top: 28px;
    font-size: 13px; color: var(--text-dim);
  }
  .footer__built { font-family: var(--mono); font-size: 12px; }

  @media (max-width: 860px) {
    .footer__top { grid-template-columns: 1fr; gap: 40px; }
  }
  @media (max-width: 560px) {
    .footer__cols { grid-template-columns: repeat(2, 1fr); gap: 32px 20px; }
  }
</style>
