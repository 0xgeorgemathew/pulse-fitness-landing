---
---

<section class="section cta-section">
  <div class="container">
    <div class="cta reveal">
      <div class="cta__bg" aria-hidden="true">
        <img
          class="cta__bg-photo"
          src="https://images.unsplash.com/photo-1534438327276-14e5300c3a48?auto=format&fit=crop&w=1600&h=700&q=80"
          alt=""
          aria-hidden="true"
          loading="lazy"
          decoding="async"
        />
        <div class="cta__bg-tint"></div>
        <div class="cta__bg-grid"></div>
        <div class="cta__bg-vignette"></div>
        <div class="cta__bg-spotlight"></div>
        <div class="cta__bg-glow cta__bg-glow--lime"></div>
        <div class="cta-glow"></div>
      </div>

      <div class="cta__content">
        <span class="chip chip--lime cta__chip">
          <span class="cta__chip-dot" aria-hidden="true"></span>
          Your move
        </span>
        <h2 class="cta__title">
          The only workout<br />
          you'll <span class="cta__title-accent">actually finish.</span>
        </h2>
        <p class="cta__lead">
          Join 2.4M athletes training with PULSE. Start your 14-day free trial today —
          no credit card, no excuses.
        </p>
        <div class="cta__actions">
          <a href="#pricing" class="btn btn--primary btn--lg cta__btn-primary">
            Start free trial
            <svg width="16" height="16" viewBox="0 0 16 16" fill="none">
              <path d="M3 8h9M8 4l4 4-4 4" stroke="currentColor" stroke-width="2"
                stroke-linecap="round" stroke-linejoin="round"/>
            </svg>
          </a>
          <a href="#workouts" class="btn btn--ghost btn--lg cta__btn-ghost">Explore workouts</a>
        </div>
        <div class="cta__stores">
          <span class="cta__store">
            <svg width="18" height="18" viewBox="0 0 24 24" fill="currentColor">
              <path d="M17.05 20.28c-.98.95-2.05.88-3.08.41-1.09-.47-2.09-.48-3.24 0-1.44.62-2.2.44-3.06-.41C2.79 15.25 3.51 7.59 9.05 7.31c1.35.07 2.29.74 3.08.8 1.18-.24 2.31-.93 3.57-.84 1.51.12 2.65.72 3.4 1.8-3.12 1.87-2.38 5.98.48 7.13-.57 1.5-1.31 2.99-2.54 4.08zM12.03 7.25c-.15-2.23 1.66-4.07 3.74-4.25.29 2.58-2.34 4.5-3.74 4.25z"/>
            </svg>
            App Store
          </span>
          <span class="cta__store">
            <svg width="18" height="18" viewBox="0 0 24 24" fill="currentColor">
              <path d="M3 20.5V3.5c0-.74.4-1.38 1-1.73L13.69 12 4 22.23c-.6-.35-1-.99-1-1.73zm10.69-7.92l2.74-1.57 4.3 4.3c.5.5.5 1.3 0 1.8l-2.4 2.4c-.5.5-1.3.5-1.8 0l-2.84-2.84 0-2.09zM5.5 1.5L17 8l-2.74 1.57L5.5 1.5z"/>
            </svg>
            Google Play
          </span>
        </div>
      </div>
    </div>
  </div>
</section>

<style>
  .cta {
    position: relative;
    overflow: hidden;
    border-radius: var(--radius-lg);
    min-height: clamp(420px, 60vw, 620px);
    padding: clamp(56px, 9vw, 104px) clamp(24px, 5vw, 64px);
    text-align: center;
    display: flex;
    align-items: center;
    justify-content: center;
    background: #050507;
    border: 1px solid var(--border-strong);
    box-shadow: var(--shadow-lg);
  }

  /* ---------- Background layers ---------- */
  .cta__bg {
    position: absolute; inset: 0;
    pointer-events: none;
    overflow: hidden;
    z-index: 0;
  }

  /* Full-bleed cinematic photo */
  .cta__bg-photo {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    object-fit: cover;
    object-position: center 40%;
    opacity: 0.4;
  }

  /* Subtle accent tint so the photo feels cohesive with the brand */
  .cta__bg-tint {
    position: absolute; inset: 0;
    background:
      linear-gradient(150deg, rgba(212, 255, 58, 0.07), transparent 45%),
      linear-gradient(210deg, rgba(255, 46, 136, 0.06), transparent 45%);
  }

  /* Subtler grid texture over the photo */
  .cta__bg-grid {
    position: absolute; inset: 0;
    background-image:
      linear-gradient(rgba(255, 255, 255, 0.022) 1px, transparent 1px),
      linear-gradient(90deg, rgba(255, 255, 255, 0.022) 1px, transparent 1px);
    background-size: 56px 56px;
    mask-image: radial-gradient(ellipse 70% 80% at 50% 50%, #000 0%, transparent 80%);
    -webkit-mask-image: radial-gradient(ellipse 70% 80% at 50% 50%, #000 0%, transparent 80%);
    opacity: 0.6;
  }

  /* Dark edges + bottom fade into page bg so text dominates */
  .cta__bg-vignette {
    position: absolute; inset: 0;
    background:
      radial-gradient(ellipse 90% 90% at 50% 45%, transparent 0%, rgba(5, 5, 7, 0.55) 70%, rgba(5, 5, 7, 0.92) 100%),
      linear-gradient(180deg, rgba(5, 5, 7, 0.55) 0%, transparent 28%, transparent 55%, var(--bg) 100%);
  }

  /* Soft radial lift directly behind the content */
  .cta__bg-spotlight {
    position: absolute; inset: 0;
    background: radial-gradient(ellipse 55% 60% at 50% 50%, rgba(212, 255, 58, 0.10) 0%, transparent 70%);
  }

  /* Static brand glow */
  .cta__bg-glow {
    position: absolute;
    border-radius: 50%;
    filter: blur(110px);
    opacity: 0.4;
  }
  .cta__bg-glow--lime {
    width: 460px; height: 460px;
    background: var(--lime);
    top: -180px; left: -120px;
    opacity: 0.22;
  }

  /* Slow drifting accent glow for cinematic life */
  .cta-glow {
    position: absolute;
    width: 520px; height: 520px;
    right: -160px; bottom: -200px;
    background: var(--pink);
    border-radius: 50%;
    filter: blur(120px);
    opacity: 0.18;
    animation: cta-drift 14s ease-in-out infinite alternate;
  }

  @keyframes cta-drift {
    0%   { transform: translate3d(0, 0, 0) scale(1);     opacity: 0.14; }
    100% { transform: translate3d(-60px, -40px, 0) scale(1.12); opacity: 0.22; }
  }

  /* ---------- Content ---------- */
  .cta__content {
    position: relative;
    z-index: 1;
    max-width: 680px;
    margin: 0 auto;
  }

  .cta__chip {
    margin-bottom: 24px;
    backdrop-filter: blur(8px);
    -webkit-backdrop-filter: blur(8px);
    box-shadow: 0 0 24px rgba(212, 255, 58, 0.18);
  }
  .cta__chip-dot {
    width: 7px; height: 7px;
    border-radius: 50%;
    background: var(--lime);
    box-shadow: 0 0 10px rgba(212, 255, 58, 0.9);
    animation: cta-pulse 2.2s ease-in-out infinite;
  }
  @keyframes cta-pulse {
    0%, 100% { opacity: 1;   transform: scale(1);    box-shadow: 0 0 8px  rgba(212, 255, 58, 0.7); }
    50%      { opacity: 0.55; transform: scale(0.82); box-shadow: 0 0 18px rgba(212, 255, 58, 0.95); }
  }

  .cta__title {
    font-family: var(--display);
    font-weight: 900;
    font-size: clamp(40px, 7vw, 80px);
    line-height: 1.0;
    letter-spacing: -0.04em;
    text-shadow: 0 6px 40px rgba(0, 0, 0, 0.6);
  }
  .cta__title-accent {
    background: linear-gradient(105deg, var(--lime) 0%, var(--orange) 60%, var(--pink) 110%);
    background-size: 200% auto;
    -webkit-background-clip: text;
    background-clip: text;
    color: transparent;
    filter: drop-shadow(0 0 26px rgba(212, 255, 58, 0.45));
    animation: cta-shimmer 6s linear infinite;
  }
  @keyframes cta-shimmer {
    0%   { background-position: 0% center; }
    100% { background-position: 200% center; }
  }

  .cta__lead {
    color: var(--text-muted);
    font-size: clamp(16px, 2vw, 19px);
    margin-top: 20px;
    max-width: 52ch;
    margin-inline: auto;
    text-shadow: 0 2px 16px rgba(0, 0, 0, 0.5);
  }

  .cta__actions {
    display: flex; flex-wrap: wrap; gap: 14px;
    justify-content: center;
    margin-top: 36px;
  }

  /* Premium primary — extra glow */
  .cta__btn-primary {
    box-shadow:
      var(--glow-lime),
      0 18px 50px -16px rgba(212, 255, 58, 0.55);
  }
  .cta__btn-primary:hover {
    box-shadow:
      0 0 64px rgba(212, 255, 58, 0.6),
      0 22px 60px -16px rgba(212, 255, 58, 0.7);
  }

  /* Frosted ghost button */
  .cta__btn-ghost {
    --btn-bg: rgba(255, 255, 255, 0.06);
    backdrop-filter: blur(12px);
    -webkit-backdrop-filter: blur(12px);
    border: 1px solid var(--border-strong);
    box-shadow: inset 0 1px 0 rgba(255, 255, 255, 0.08);
  }
  .cta__btn-ghost:hover {
    background: rgba(255, 255, 255, 0.1);
    border-color: rgba(255, 255, 255, 0.3);
  }

  /* Frosted glass app-store pills */
  .cta__stores {
    display: flex; gap: 12px; justify-content: center; flex-wrap: wrap;
    margin-top: 36px;
  }
  .cta__store {
    display: inline-flex; align-items: center; gap: 9px;
    padding: 10px 18px;
    border-radius: 999px;
    font-size: 13.5px;
    font-weight: 600;
    color: var(--text-muted);
    background: rgba(255, 255, 255, 0.05);
    border: 1px solid var(--border);
    backdrop-filter: blur(10px);
    -webkit-backdrop-filter: blur(10px);
    box-shadow: inset 0 1px 0 rgba(255, 255, 255, 0.06);
    transition: color 0.2s ease, border-color 0.2s ease, background 0.2s ease;
  }
  .cta__store:hover {
    color: var(--text);
    border-color: var(--border-strong);
    background: rgba(255, 255, 255, 0.08);
  }
  .cta__store svg { opacity: 0.9; }

  /* ---------- Reduced motion ---------- */
  @media (prefers-reduced-motion: reduce) {
    .cta-glow,
    .cta__chip-dot,
    .cta__title-accent { animation: none !important; }
    .cta__title-accent { background-position: 0% center; }
  }

  /* ---------- Responsive ---------- */
  @media (max-width: 640px) {
    .cta { min-height: 0; }
    .cta__actions { flex-direction: column; align-items: stretch; }
    .cta__actions .btn { width: 100%; }
  }
</style>
