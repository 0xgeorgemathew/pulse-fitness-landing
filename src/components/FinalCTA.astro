---
---

<section class="section cta-section">
  <div class="container">
    <div class="cta reveal">
      <div class="cta__bg" aria-hidden="true">
        <div class="cta__bg-grid"></div>
        <div class="cta__bg-glow cta__bg-glow--lime"></div>
        <div class="cta__bg-glow cta__bg-glow--pink"></div>
      </div>

      <div class="cta__content">
        <span class="chip chip--lime">Your move</span>
        <h2 class="cta__title">
          The only workout<br />
          you'll <span class="cta__title-accent">actually finish.</span>
        </h2>
        <p class="cta__lead">
          Join 2.4M athletes training with PULSE. Start your 14-day free trial today —
          no credit card, no excuses.
        </p>
        <div class="cta__actions">
          <a href="#pricing" class="btn btn--primary btn--lg">
            Start free trial
            <svg width="16" height="16" viewBox="0 0 16 16" fill="none">
              <path d="M3 8h9M8 4l4 4-4 4" stroke="currentColor" stroke-width="2"
                stroke-linecap="round" stroke-linejoin="round"/>
            </svg>
          </a>
          <a href="#workouts" class="btn btn--ghost btn--lg">Explore workouts</a>
        </div>
        <div class="cta__stores">
          <span class="cta__store">
            <svg width="18" height="18" viewBox="0 0 24 24" fill="currentColor">
              <path d="M17.05 20.28c-.98.95-2.05.88-3.08.41-1.09-.47-2.09-.48-3.24 0-1.44.62-2.2.44-3.06-.41C2.79 15.25 3.51 7.59 9.05 7.31c1.35.07 2.29.74 3.08.8 1.18-.24 2.31-.93 3.57-.84 1.51.12 2.65.72 3.4 1.8-3.12 1.87-2.38 5.98.48 7.13-.57 1.5-1.31 2.99-2.54 4.08zM12.03 7.25c-.15-2.23 1.66-4.07 3.74-4.25.29 2.58-2.34 4.5-3.74 4.25z"/>
            </svg>
            App Store
          </span>
          <span class="cta__store">
            <svg width="18" height="18" viewBox="0 0 24 24" fill="currentColor">
              <path d="M3 20.5V3.5c0-.74.4-1.38 1-1.73L13.69 12 4 22.23c-.6-.35-1-.99-1-1.73zm10.69-7.92l2.74-1.57 4.3 4.3c.5.5.5 1.3 0 1.8l-2.4 2.4c-.5.5-1.3.5-1.8 0l-2.84-2.84 0-2.09zM5.5 1.5L17 8l-2.74 1.57L5.5 1.5z"/>
            </svg>
            Google Play
          </span>
        </div>
      </div>
    </div>
  </div>
</section>

<style>
  .cta {
    position: relative;
    overflow: hidden;
    border-radius: var(--radius-lg);
    padding: clamp(48px, 8vw, 88px) clamp(24px, 5vw, 64px);
    text-align: center;
    background: linear-gradient(180deg, #0e0e14, #08080b);
    border: 1px solid var(--border-strong);
  }
  .cta__bg {
    position: absolute; inset: 0;
    pointer-events: none;
    overflow: hidden;
  }
  .cta__bg-grid {
    position: absolute; inset: 0;
    background-image:
      linear-gradient(rgba(212, 255, 58, 0.04) 1px, transparent 1px),
      linear-gradient(90deg, rgba(212, 255, 58, 0.04) 1px, transparent 1px);
    background-size: 48px 48px;
    mask-image: radial-gradient(ellipse 70% 80% at 50% 50%, #000 0%, transparent 80%);
    -webkit-mask-image: radial-gradient(ellipse 70% 80% at 50% 50%, #000 0%, transparent 80%);
  }
  .cta__bg-glow {
    position: absolute;
    border-radius: 50%;
    filter: blur(90px);
    opacity: 0.5;
  }
  .cta__bg-glow--lime {
    width: 400px; height: 400px;
    background: var(--lime);
    top: -150px; left: -100px;
  }
  .cta__bg-glow--pink {
    width: 380px; height: 380px;
    background: var(--pink);
    bottom: -150px; right: -100px;
    opacity: 0.3;
  }

  .cta__content {
    position: relative;
    z-index: 1;
    max-width: 640px;
    margin: 0 auto;
  }
  .cta__content .chip { margin-bottom: 22px; }

  .cta__title {
    font-family: var(--display);
    font-weight: 900;
    font-size: clamp(36px, 6vw, 64px);
    line-height: 1.02;
    letter-spacing: -0.035em;
  }
  .cta__title-accent {
    background: linear-gradient(105deg, var(--lime), var(--orange));
    -webkit-background-clip: text;
    background-clip: text;
    color: transparent;
  }
  .cta__lead {
    color: var(--text-muted);
    font-size: clamp(16px, 2vw, 18px);
    margin-top: 18px;
    max-width: 50ch;
    margin-inline: auto;
  }
  .cta__actions {
    display: flex; flex-wrap: wrap; gap: 14px;
    justify-content: center;
    margin-top: 32px;
  }
  .cta__stores {
    display: flex; gap: 28px; justify-content: center;
    margin-top: 32px;
    color: var(--text-dim);
    font-size: 13.5px;
  }
  .cta__store {
    display: inline-flex; align-items: center; gap: 8px;
    font-weight: 600;
  }
</style>
