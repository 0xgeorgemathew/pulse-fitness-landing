---
import { workouts } from "../data/site";

const accentVar = {
  lime: "var(--lime)",
  orange: "var(--orange)",
  pink: "var(--pink)",
  blue: "var(--blue)",
};

const intensityMap = { Low: 1, Medium: 2, High: 3, Max: 4 };
---

<section class="section" id="workouts">
  <div class="container">
    <div class="section-head reveal">
      <span class="eyebrow">The library</span>
      <h2 class="section-title">Workouts that <em>never get easy.</em></h2>
      <p class="section-lead">
        600+ on-demand classes and 180+ live sessions every week — across strength,
        HIIT, yoga, boxing, cardio, and mobility. Filter, favorite, and let the
        adaptive engine pick your next session.
      </p>
    </div>

    <div class="filters reveal" role="group" aria-label="Filter workouts by category">
      <button class="filter is-active" data-filter="all">All</button>
      <button class="filter" data-filter="Strength">Strength</button>
      <button class="filter" data-filter="HIIT">HIIT</button>
      <button class="filter" data-filter="Cardio">Cardio</button>
      <button class="filter" data-filter="Boxing">Boxing</button>
      <button class="filter" data-filter="Yoga">Yoga</button>
      <button class="filter" data-filter="Mobility">Mobility</button>
    </div>

    <div class="cards" data-grid>
      {workouts.map((w) => (
        <article class="card workout reveal" data-category={w.category} style={`--accent:${accentVar[w.accent]}`}>
          <div class="workout__hero">
            <img
              class="workout__img"
              src={w.image}
              alt=""
              width="640"
              height="400"
              loading="lazy"
              decoding="async"
            />
            <div class="workout__overlay" aria-hidden="true"></div>

            <span class="chip chip--{w.accent} workout__chip">{w.category}</span>
            <span
              class="workout__intensity"
              aria-hidden="true"
            >
              {Array.from({ length: 4 }).map((_, i) => (
                <span class={`bar ${i < intensityMap[w.intensity] ? "on" : ""}`}></span>
              ))}
            </span>
            <span class="sr-only">Intensity {w.intensity}</span>

            <div class="workout__play" aria-hidden="true">
              <svg width="22" height="22" viewBox="0 0 22 22" fill="none">
                <path d="M6 4 L17 11 L6 18 Z" fill="currentColor"/>
              </svg>
            </div>

            <span class="workout__duration">{w.duration} min</span>
          </div>

          <div class="workout__body">
            <h3 class="workout__title">{w.title}</h3>
            <p class="workout__blurb">{w.blurb}</p>

            <ul class="workout__moves">
              {w.moves.slice(0, 3).map((m) => <li>{m}</li>)}
            </ul>

            <div class="workout__meta">
              <span>
                <svg width="14" height="14" viewBox="0 0 14 14" fill="none">
                  <path d="M7 1v6l4 2" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"/>
                  <circle cx="7" cy="7" r="6" stroke="currentColor" stroke-width="1.5"/>
                </svg>
                {w.duration} min
              </span>
              <span>
                <svg width="14" height="14" viewBox="0 0 14 14" fill="none">
                  <path d="M7 1c2 3 4 5 4 8a4 4 0 1 1-8 0c0-3 2-5 4-8z" stroke="currentColor" stroke-width="1.5" stroke-linejoin="round"/>
                </svg>
                {w.kcal} kcal
              </span>
              <span class="workout__coach">with {w.coach}</span>
            </div>
          </div>
        </article>
      ))}
    </div>

    <div class="workouts__foot reveal">
      <a href="#pricing" class="btn btn--ghost">
        Browse all 600+ workouts
        <svg width="16" height="16" viewBox="0 0 16 16" fill="none">
          <path d="M3 8h9M8 4l4 4-4 4" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/>
        </svg>
      </a>
    </div>
  </div>
</section>

<style>
  .filters {
    display: flex; flex-wrap: wrap; gap: 8px;
    margin-bottom: 32px;
  }
  .filter {
    padding: 9px 18px;
    border-radius: 999px;
    font-size: 13.5px; font-weight: 600;
    color: var(--text-muted);
    background: var(--bg-elev);
    border: 1px solid var(--border);
    transition: all 0.18s ease;
  }
  .filter:hover { color: var(--text); border-color: var(--border-strong); }
  .filter.is-active {
    background: var(--lime); color: #08080b;
    border-color: var(--lime);
  }

  .cards {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(320px, 1fr));
    gap: 20px;
  }

  .workout {
    overflow: hidden;
    display: flex; flex-direction: column;
    transition: transform 0.25s ease, border-color 0.25s ease, box-shadow 0.25s ease;
  }
  .workout:hover {
    transform: translateY(-4px);
    border-color: var(--accent);
    box-shadow: var(--shadow-lg);
  }
  .workout.is-hidden { display: none; }

  /* ---------- Media / photo thumbnail ---------- */
  .workout__hero {
    position: relative;
    aspect-ratio: 16 / 10;
    overflow: hidden;
    background: var(--bg-elev-2);
  }
  .workout__img {
    position: absolute; inset: 0;
    width: 100%; height: 100%;
    object-fit: cover;
    transition: transform 0.5s cubic-bezier(0.16, 1, 0.3, 1);
    will-change: transform;
  }
  .workout:hover .workout__img { transform: scale(1.06); }

  /* Layered overlay: accent tint at top + dark blend at bottom. */
  .workout__overlay {
    position: absolute; inset: 0;
    background:
      linear-gradient(180deg, color-mix(in srgb, var(--accent) 25%, transparent), transparent 50%),
      linear-gradient(180deg, transparent 40%, rgba(8, 8, 11, 0.85));
    pointer-events: none;
  }

  /* Meta sitting on the photo */
  .workout__chip {
    position: absolute; top: 14px; left: 14px;
    z-index: 2;
  }
  .workout__intensity {
    position: absolute; top: 16px; right: 14px;
    z-index: 2;
    display: inline-flex; gap: 3px; align-items: flex-end;
  }
  .workout__intensity .bar {
    width: 4px; height: 14px;
    background: rgba(255, 255, 255, 0.2);
    border-radius: 2px;
  }
  .workout__intensity .bar.on { background: var(--accent); }

  .workout__play {
    position: absolute; top: 50%; left: 50%;
    transform: translate(-50%, -50%);
    z-index: 2;
    width: 52px; height: 52px;
    border-radius: 50%;
    background: rgba(255, 255, 255, 0.92);
    color: #08080b;
    display: grid; place-items: center;
    transition: transform 0.25s cubic-bezier(0.16, 1, 0.3, 1), background 0.2s ease;
    box-shadow: 0 10px 30px rgba(0, 0, 0, 0.45);
  }
  .workout:hover .workout__play { transform: translate(-50%, -50%) scale(1.1); }
  .workout__play svg { margin-left: 3px; }

  .workout__duration {
    position: absolute; bottom: 12px; right: 12px;
    z-index: 2;
    font-family: var(--mono);
    font-size: 11px; font-weight: 700;
    padding: 4px 9px;
    background: rgba(0, 0, 0, 0.55);
    backdrop-filter: blur(8px);
    border-radius: 6px;
    border: 1px solid var(--border);
  }

  /* ---------- Body ---------- */
  .workout__body { padding: 16px 18px 18px; display: flex; flex-direction: column; flex: 1; }
  .workout__title {
    font-size: 22px; font-weight: 800; letter-spacing: -0.02em;
  }
  .workout__blurb {
    color: var(--text-muted); font-size: 14px;
    margin-top: 6px;
  }
  .workout__moves {
    display: flex; flex-wrap: wrap; gap: 6px;
    margin-top: 12px;
  }
  .workout__moves li {
    font-size: 11.5px;
    font-family: var(--mono);
    color: var(--text-muted);
    background: var(--bg-elev-2);
    border: 1px solid var(--border);
    padding: 4px 9px;
    border-radius: 6px;
  }
  .workout__meta {
    display: flex; flex-wrap: wrap; gap: 14px;
    align-items: center;
    margin-top: auto; padding-top: 14px;
    font-size: 12.5px;
    color: var(--text-muted);
    border-top: 1px solid var(--border);
  }
  .workout__meta span {
    display: inline-flex; align-items: center; gap: 5px;
  }
  .workout__meta svg { color: var(--accent); }
  .workout__coach {
    margin-left: auto;
    color: var(--text);
    font-weight: 600;
  }

  .workouts__foot {
    display: flex; justify-content: center;
    margin-top: 40px;
  }
</style>

<script>
  // Category filter — vanilla, no framework.
  const filters = document.querySelectorAll<HTMLButtonElement>(".filter");
  const cards = document.querySelectorAll<HTMLElement>(".workout");

  filters.forEach((btn) => {
    btn.addEventListener("click", () => {
      filters.forEach((b) => b.classList.remove("is-active"));
      btn.classList.add("is-active");
      const cat = btn.dataset.filter;
      cards.forEach((card) => {
        const show = cat === "all" || card.dataset.category === cat;
        card.classList.toggle("is-hidden", !show);
      });
    });
  });
</script>
