---
import { workouts } from "../data/site";

const accentVar = {
  lime: "var(--lime)",
  orange: "var(--orange)",
  pink: "var(--pink)",
  blue: "var(--blue)",
};

const intensityMap = { Low: 1, Medium: 2, High: 3, Max: 4 };
---

<section class="section" id="workouts">
  <div class="container">
    <div class="section-head reveal">
      <span class="eyebrow">The library</span>
      <h2 class="section-title">Workouts that <em>never get easy.</em></h2>
      <p class="section-lead">
        600+ on-demand classes and 180+ live sessions every week — across strength,
        HIIT, yoga, boxing, cardio, and mobility. Filter, favorite, and let the
        adaptive engine pick your next session.
      </p>
    </div>

    <div class="filters reveal" role="group" aria-label="Filter workouts by category">
      <button class="filter is-active" data-filter="all">All</button>
      <button class="filter" data-filter="Strength">Strength</button>
      <button class="filter" data-filter="HIIT">HIIT</button>
      <button class="filter" data-filter="Cardio">Cardio</button>
      <button class="filter" data-filter="Boxing">Boxing</button>
      <button class="filter" data-filter="Yoga">Yoga</button>
      <button class="filter" data-filter="Mobility">Mobility</button>
      <span class="filter__count" data-count aria-live="polite">
        Showing <strong>6</strong> of 6
      </span>
    </div>

    <div class="cards" data-grid>
      {workouts.map((w) => (
        <article class="card workout reveal" data-category={w.category} style={`--accent:${accentVar[w.accent]}`}>
          <div class="workout__hero">
            <img
              class="workout__img"
              src={w.image}
              alt=""
              width="640"
              height="400"
              loading="lazy"
              decoding="async"
            />
            {/* Editorial duotone stack (bottom → top):
                1. __duotone — dark base layer + accent blend-mode tint (cinematic highlights → accent, shadows → near-black)
                2. __vignette — radial darkening at the edges for depth
                3. __overlay — strong bottom-up gradient to guarantee text legibility
                4. __tint — subtle accent wash from the top, lifts on hover */}
            <div class="workout__duotone" aria-hidden="true"></div>
            <div class="workout__vignette" aria-hidden="true"></div>
            <div class="workout__overlay" aria-hidden="true"></div>
            <div class="workout__tint" aria-hidden="true"></div>

            <span class="chip chip--{w.accent} workout__chip">{w.category}</span>
            <span
              class="workout__intensity"
              aria-hidden="true"
            >
              {Array.from({ length: 4 }).map((_, i) => (
                <span class={`bar ${i < intensityMap[w.intensity] ? "on" : ""}`}></span>
              ))}
            </span>
            <span class="sr-only">Intensity {w.intensity}</span>

            <div class="workout__play" aria-hidden="true">
              <svg width="22" height="22" viewBox="0 0 22 22" fill="none">
                <path d="M6 4 L17 11 L6 18 Z" fill="currentColor"/>
              </svg>
            </div>

            <span class="workout__duration">{w.duration} min</span>
          </div>

          <div class="workout__body">
            <h3 class="workout__title">{w.title}</h3>
            <p class="workout__blurb">{w.blurb}</p>

            <ul class="workout__moves">
              {w.moves.slice(0, 3).map((m) => <li>{m}</li>)}
            </ul>

            <div class="workout__meta">
              <span>
                <svg width="14" height="14" viewBox="0 0 14 14" fill="none">
                  <path d="M7 1v6l4 2" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"/>
                  <circle cx="7" cy="7" r="6" stroke="currentColor" stroke-width="1.5"/>
                </svg>
                {w.duration} min
              </span>
              <span>
                <svg width="14" height="14" viewBox="0 0 14 14" fill="none">
                  <path d="M7 1c2 3 4 5 4 8a4 4 0 1 1-8 0c0-3 2-5 4-8z" stroke="currentColor" stroke-width="1.5" stroke-linejoin="round"/>
                </svg>
                {w.kcal} kcal
              </span>
              <span class="workout__coach">with {w.coach}</span>
            </div>
          </div>
        </article>
      ))}
    </div>

    <div class="workouts__foot reveal">
      <a href="#pricing" class="btn btn--ghost">
        Browse all 600+ workouts
        <svg width="16" height="16" viewBox="0 0 16 16" fill="none">
          <path d="M3 8h9M8 4l4 4-4 4" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/>
        </svg>
      </a>
    </div>
  </div>
</section>

<style>
  .filters {
    display: flex; flex-wrap: wrap; gap: 8px;
    align-items: center;
    margin-bottom: 32px;
  }
  .filter {
    padding: 9px 18px;
    border-radius: 999px;
    font-size: 13.5px; font-weight: 600;
    color: var(--text-muted);
    background: var(--bg-elev);
    border: 1px solid var(--border);
    transition: color 0.18s ease, border-color 0.18s ease, box-shadow 0.25s ease, background 0.18s ease;
  }
  .filter:hover { color: var(--text); border-color: var(--border-strong); }
  .filter.is-active {
    background: var(--lime); color: #08080b;
    border-color: var(--lime);
    box-shadow: 0 0 0 1px var(--lime), 0 0 28px rgba(212, 255, 58, 0.45);
  }
  .filter__count {
    margin-left: auto;
    font-family: var(--mono);
    font-size: 11.5px;
    letter-spacing: 0.04em;
    color: var(--text-dim);
    text-transform: uppercase;
  }
  .filter__count strong {
    color: var(--lime);
    font-weight: 700;
  }

  .cards {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(320px, 1fr));
    gap: 20px;
  }

  .workout {
    overflow: hidden;
    display: flex; flex-direction: column;
    transition: transform 0.3s cubic-bezier(0.16, 1, 0.3, 1), border-color 0.3s ease, box-shadow 0.3s ease;
  }
  .workout:hover {
    transform: translateY(-6px);
    border-color: color-mix(in srgb, var(--accent) 60%, transparent);
    box-shadow:
      var(--shadow-lg),
      0 0 0 1px color-mix(in srgb, var(--accent) 35%, transparent),
      0 0 48px -12px color-mix(in srgb, var(--accent) 50%, transparent);
  }
  .workout.is-hidden { display: none; }

  /* ---------- Media / photo thumbnail ---------- */
  .workout__hero {
    position: relative;
    /* Editorial 3/2 crop — more cinematic than the old 4/3. */
    aspect-ratio: 3 / 2;
    overflow: hidden;
    background: var(--bg-elev-2);
    /* Slight base darkening so the duotone blend has something to bite into. */
    isolation: isolate;
  }
  .workout__img {
    position: absolute; inset: 0;
    width: 100%; height: 100%;
    object-fit: cover;
    /* Keep the athletic subject reading well at the top of the frame. */
    object-position: center top;
    /* Brighten slightly so the accent tint reads as glow, not mud. */
    filter: contrast(1.08) saturate(1.05) brightness(1.02);
    transition: transform 0.8s cubic-bezier(0.16, 1, 0.3, 1), filter 0.5s ease;
    will-change: transform;
  }
  .workout:hover .workout__img {
    transform: scale(1.08);
    /* On hover, push contrast/sat back toward true — the tint lifts, real photo shows. */
    filter: contrast(1.04) saturate(1.1) brightness(1.05);
  }

  /* ---------- Editorial duotone stack ---------- */
  /* The photo + this layer together = duotone: highlights pushed toward the accent,
     shadows held near black. Sits ABOVE the image but BELOW legibility gradient. */
  .workout__duotone {
    position: absolute; inset: 0;
    /* Solid accent behind the blend + a dark wash, blended onto the photo. */
    background:
      linear-gradient(180deg,
        color-mix(in srgb, var(--accent) 30%, transparent) 0%,
        color-mix(in srgb, var(--accent) 12%, transparent) 55%,
        rgba(8, 8, 11, 0.55) 100%);
    mix-blend-mode: color-dodge;
    opacity: 0.55;
    transition: opacity 0.5s ease, mix-blend-mode 0s;
    pointer-events: none;
    z-index: 1;
  }
  /* A second, subtler accent multiply layer to deepen the tint in midtones
     without crushing contrast — this is the "cinematic wash" half of the duotone. */
  .workout__hero::after {
    content: "";
    position: absolute; inset: 0;
    background: var(--accent);
    mix-blend-mode: soft-light;
    opacity: 0.4;
    pointer-events: none;
    z-index: 1;
    transition: opacity 0.5s ease;
  }

  /* Vignette — darker edges for depth and to focus the subject. */
  .workout__vignette {
    position: absolute; inset: 0;
    background: radial-gradient(120% 100% at 50% 35%,
      transparent 40%,
      rgba(8, 8, 11, 0.35) 75%,
      rgba(8, 8, 11, 0.7) 100%);
    pointer-events: none;
    z-index: 2;
  }

  /* Legibility gradient — bottom-up, strong enough to keep copy readable
     even with the duotone underneath. This is the non-negotiable layer. */
  .workout__overlay {
    position: absolute; inset: 0;
    background: linear-gradient(180deg,
      transparent 30%,
      rgba(8, 8, 11, 0.75) 70%,
      rgba(8, 8, 11, 0.95));
    pointer-events: none;
    z-index: 2;
  }
  /* Top accent wash — adds brand color into the sky/highlight region.
     Lifts on hover so the true photo shows through. */
  .workout__tint {
    position: absolute; inset: 0;
    background: linear-gradient(180deg,
      color-mix(in srgb, var(--accent) 30%, transparent),
      transparent 45%);
    opacity: 0.7;
    transition: opacity 0.4s ease;
    pointer-events: none;
    z-index: 2;
  }

  /* Hover: the whole duotone lifts — photo reveals, tint recedes. */
  .workout:hover .workout__duotone { opacity: 0.25; }
  .workout:hover .workout__hero::after { opacity: 0.15; }
  .workout:hover .workout__tint { opacity: 0.3; }

  /* Meta sitting on the photo */
  .workout__chip {
    position: absolute; top: 14px; left: 14px;
    z-index: 3;
    /* Frosted-glass override of .chip--accent tint for a premium on-photo badge. */
    background: rgba(0, 0, 0, 0.5);
    backdrop-filter: blur(8px);
    -webkit-backdrop-filter: blur(8px);
    border: 1px solid rgba(255, 255, 255, 0.1);
  }
  .workout__intensity {
    position: absolute; top: 16px; right: 14px;
    z-index: 3;
    display: inline-flex; gap: 3px; align-items: flex-end;
  }
  .workout__intensity .bar {
    width: 4px; height: 14px;
    background: rgba(255, 255, 255, 0.2);
    border-radius: 2px;
  }
  .workout__intensity .bar.on { background: var(--accent); }

  .workout__play {
    position: absolute; top: 50%; left: 50%;
    transform: translate(-50%, -50%) scale(0.92);
    z-index: 3;
    width: 56px; height: 56px;
    border-radius: 50%;
    background: rgba(255, 255, 255, 0.92);
    color: #08080b;
    display: grid; place-items: center;
    transition: transform 0.35s cubic-bezier(0.16, 1, 0.3, 1), background 0.3s ease, box-shadow 0.35s ease;
    box-shadow: 0 10px 30px rgba(0, 0, 0, 0.5);
  }
  .workout:hover .workout__play {
    transform: translate(-50%, -50%) scale(1.12);
    background: var(--accent);
    box-shadow:
      0 0 0 4px color-mix(in srgb, var(--accent) 25%, transparent),
      0 12px 36px rgba(0, 0, 0, 0.55),
      0 0 40px color-mix(in srgb, var(--accent) 55%, transparent);
  }
  .workout__play svg { margin-left: 3px; }

  .workout__duration {
    position: absolute; bottom: 12px; right: 12px;
    z-index: 3;
    font-family: var(--mono);
    font-size: 11px; font-weight: 700;
    letter-spacing: 0.02em;
    padding: 5px 10px;
    color: var(--text);
    background: rgba(0, 0, 0, 0.5);
    backdrop-filter: blur(8px);
    -webkit-backdrop-filter: blur(8px);
    border-radius: 7px;
    border: 1px solid rgba(255, 255, 255, 0.1);
  }

  /* ---------- Body ---------- */
  .workout__body { padding: 16px 18px 18px; display: flex; flex-direction: column; flex: 1; }
  .workout__title {
    font-size: 22px; font-weight: 800; letter-spacing: -0.02em;
    transition: transform 0.35s cubic-bezier(0.16, 1, 0.3, 1), color 0.3s ease;
  }
  .workout:hover .workout__title {
    transform: translateY(-2px);
    color: color-mix(in srgb, var(--accent) 22%, var(--text));
  }
  .workout__blurb {
    color: var(--text-muted); font-size: 14px;
    margin-top: 6px;
  }
  .workout__moves {
    display: flex; flex-wrap: wrap; gap: 6px;
    margin-top: 12px;
  }
  .workout__moves li {
    font-size: 11.5px;
    font-family: var(--mono);
    color: var(--text-muted);
    background: var(--bg-elev-2);
    border: 1px solid var(--border);
    padding: 4px 9px;
    border-radius: 6px;
  }
  .workout__meta {
    display: flex; flex-wrap: wrap; gap: 14px;
    align-items: center;
    margin-top: auto; padding-top: 14px;
    font-size: 12.5px;
    color: var(--text-muted);
    border-top: 1px solid var(--border);
  }
  .workout__meta span {
    display: inline-flex; align-items: center; gap: 5px;
  }
  .workout__meta svg { color: var(--accent); }
  .workout__coach {
    margin-left: auto;
    color: var(--text);
    font-weight: 600;
  }

  .workouts__foot {
    display: flex; justify-content: center;
    margin-top: 40px;
  }

  /* ---------- Motion-safe: kill transforms on hover, keep color/shadow. ---------- */
  @media (prefers-reduced-motion: reduce) {
    .workout,
    .workout__img,
    .workout__title,
    .workout__play,
    .workout__duotone,
    .workout__tint,
    .workout__hero::after { transition: none !important; }
    .workout:hover,
    .workout:hover .workout__img,
    .workout:hover .workout__title { transform: none; }
    .workout:hover .workout__play { transform: translate(-50%, -50%); }
    /* Still reveal the photo a touch on hover even without motion. */
    .workout:hover .workout__duotone { opacity: 0.35; }
    .workout:hover .workout__tint { opacity: 0.4; }
  }
</style>

<script>
  // Category filter — vanilla, no framework.
  const filters = document.querySelectorAll<HTMLButtonElement>(".filter");
  const cards = document.querySelectorAll<HTMLElement>(".workout");
  const countEl = document.querySelector<HTMLElement>("[data-count] strong");
  const total = cards.length;

  const updateCount = () => {
    if (!countEl) return;
    const visible = Array.from(cards).filter((c) => !c.classList.contains("is-hidden")).length;
    countEl.textContent = String(visible);
  };

  filters.forEach((btn) => {
    btn.addEventListener("click", () => {
      filters.forEach((b) => b.classList.remove("is-active"));
      btn.classList.add("is-active");
      const cat = btn.dataset.filter;
      cards.forEach((card) => {
        const show = cat === "all" || card.dataset.category === cat;
        card.classList.toggle("is-hidden", !show);
      });
      updateCount();
    });
  });
</script>
